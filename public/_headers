/*
  Content-Security-Policy: default-src 'self'; font-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://assets.taskade.com; connect-src 'self' https://taskade.com https://www.taskade.com https://assets.taskade.com; frame-src 'self' https://taskade.com https://www.taskade.com; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Stable brand assets — cache for a week, revalidate after
/og-image.png
  Cache-Control: public, max-age=604800
/markosh-logo.png
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/favicon-16.png
  Cache-Control: public, max-age=604800
/favicon-32.png
  Cache-Control: public, max-age=604800
