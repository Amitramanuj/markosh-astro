---
import { Image } from 'astro:assets';
import Button from '@/components/ui/Button.astro';
import heroTeam from '@/assets/hero-team.jpg';

const stats = [
  { value: '120+', label: 'Engineers placed' },
  { value: '8+', label: 'Industries served' },
  { value: '95%', label: 'Client retention' },
  { value: '2 wks', label: 'Avg. team kickoff' },
];

// TODO(content): Replace with real client names/logos before launch.
const clientWordmarks = ['FinPay Co.', 'CareBridge', 'DocuFlow AI', 'ShopLane', 'EduSpark'];
---

<section class="relative isolate overflow-hidden pt-10 pb-16 md:pt-20 md:pb-24">
  <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>

  <div class="container mx-auto">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr,1fr]">
      <div class="max-w-xl text-center lg:text-left">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">
          IT Staffing · Custom Software · AI
        </p>

        <h1 class="mt-6 font-headline text-[2.5rem] font-bold leading-[1.05] tracking-tight sm:text-6xl sm:leading-[1.02] lg:text-7xl">
          Senior engineers, embedded <span class="text-primary">in your team.</span>
        </h1>

        <p class="mt-6 text-lg leading-8 text-muted-foreground">
          Markosh places pre-vetted developers, designers, and AI specialists inside ambitious companies — and builds the custom software your roadmap depends on.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
          <Button href="/contact" size="lg" class="btn-gradient h-12 px-8 text-base font-semibold">
            Hire Talent
            <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </Button>
          <Button href="/services" size="lg" variant="outline" class="h-12 rounded-full border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
            Explore Services
          </Button>
        </div>

        <!-- Client wordmark strip -->
        <div class="mt-12">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">Trusted across industries</p>
          <ul class="mt-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 lg:justify-start">
            {clientWordmarks.map((name) => (
              <li class="font-headline text-lg font-bold text-foreground/35">{name}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-lg">
        <!-- Offset editorial frame -->
        <div class="absolute -bottom-4 -right-4 h-full w-full rounded-2xl border border-primary/30" aria-hidden="true"></div>
        <Image
          src={heroTeam}
          alt="Markosh engineers collaborating with a client team"
          width={600}
          height={400}
          densities={[1, 2]}
          sizes="(max-width: 1024px) 100vw, 600px"
          class="relative z-10 rounded-2xl shadow-xl"
          loading="eager"
          quality={80}
          fetchpriority="high"
        />
      </div>
    </div>

    <!-- Proof strip -->
    <dl class="mt-16 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-border bg-border md:grid-cols-4">
      {stats.map((stat) => (
        <div class="bg-card px-6 py-6 text-center">
          <dd class="font-headline text-3xl font-bold text-primary">{stat.value}</dd>
          <dt class="mt-1 text-sm text-muted-foreground">{stat.label}</dt>
        </div>
      ))}
    </dl>
  </div>
</section>
