---
import Button from '@/components/ui/Button.astro';

const stats = [
  { value: '120+', label: 'Engineers placed' },
  { value: '8+', label: 'Industries served' },
  { value: '95%', label: 'Client retention' },
  { value: '2 wks', label: 'Avg. team kickoff' },
];

const operatingContexts = [
  'US startup teams',
  'Fintech platforms',
  'AI-enabled SaaS',
  'B2B revenue teams',
];

const deliverySignals = [
  'Screened by engineers',
  'Founder-led delivery',
  'US-aligned overlap',
];
---

<section class="relative isolate overflow-hidden pt-10 pb-14 md:pt-24 md:pb-24">
  <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>

  <div class="container mx-auto">
    <div class="max-w-5xl">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">
        AI Strategy · Software · Talent · Revenue
      </p>

      <h1 class="mt-6 font-headline text-[2.6rem] font-bold leading-[1.04] tracking-tight sm:text-6xl sm:leading-[1.02] md:text-7xl lg:text-8xl">
        Build smarter. Staff faster. <span class="text-primary">Sell with intelligence.</span>
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-8 text-muted-foreground">
        Markosh is an AI-first execution partner. We combine AI-assisted research, vetted human talent, and managed delivery to turn strategy into execution across product, engineering, and revenue.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <Button href="/contact" size="lg" class="btn-gradient h-12 px-8 text-base font-semibold">
          Talk to Markosh
          <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </Button>
        <Button href="/services" size="lg" variant="outline" class="h-12 rounded-full border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
          Explore Services
        </Button>
      </div>

      <dl class="mt-14 grid grid-cols-2 gap-x-8 gap-y-8 border-t border-border pt-8 sm:grid-cols-4">
        {stats.map((stat) => (
          <div>
            <dd class="font-mono text-3xl font-medium tracking-tight sm:text-4xl">{stat.value}</dd>
            <dt class="mt-2 text-xs uppercase tracking-[0.14em] text-muted-foreground">{stat.label}</dt>
          </div>
        ))}
      </dl>

      <div class="mt-10 space-y-2.5">
        <p class="font-mono text-xs leading-6 text-muted-foreground sm:text-sm">
          {deliverySignals.join(' · ')}
        </p>
        <p class="font-mono text-xs leading-6 text-muted-foreground sm:text-sm">
          <span class="uppercase tracking-[0.14em]">Built for</span> — {operatingContexts.join(' · ')}
        </p>
      </div>
    </div>
  </div>
</section>
