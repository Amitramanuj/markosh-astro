---
import { Image } from 'astro:assets';
import AnveshaAvatar from '../../../Anvesha.png';
import AmitAvatar from '../../../Amit.png';

// TODO(content): Verify each operational claim below reflects actual practice before launch.
const commitments = [
  {
    title: 'US time-zone overlap',
    description: 'Guaranteed 4+ hours of EST overlap with daily standups in your working hours.',
  },
  {
    title: 'NDA-first, IP yours',
    description: 'We sign your NDA before any discovery call, and every contract assigns full IP ownership to you.',
  },
  {
    title: 'Security by default',
    description: 'Access-controlled repos, least-privilege credentials, and client-owned infrastructure from day one.',
  },
  {
    title: 'No middle layer',
    description: 'You talk directly to the engineers doing the work — and to the founders, whenever you want.',
  },
];

const founders = [
  { name: 'Anvesha Bhatore', title: 'Co-founder', avatar: AnveshaAvatar },
  { name: 'Amit Ramanuj', title: 'Co-founder', avatar: AmitAvatar },
];
---

<section class="bg-background">
  <div class="container mx-auto">
    <div class="grid gap-14 lg:grid-cols-[1.4fr,1fr] lg:items-start">
      <div>
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">05 — Why US Companies Work With Us</p>
        <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
          Global engineering, <span class="text-primary">US-aligned delivery</span>
        </h2>
        <p class="mt-6 text-lg text-muted-foreground">
          We know what working with a remote partner needs to feel like: responsive, transparent, and contractually safe. Here is how we run every engagement.
        </p>

        <dl class="mt-12 grid gap-x-10 gap-y-8 sm:grid-cols-2">
          {commitments.map((item) => (
            <div class="border-t border-border pt-5">
              <dt class="font-headline text-lg font-bold">{item.title}</dt>
              <dd class="mt-2 text-muted-foreground">{item.description}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="border-t-2 border-foreground pt-6 lg:sticky lg:top-28">
        <h3 class="font-headline text-xl font-bold">Founder-led, by design</h3>
        <p class="mt-2 text-muted-foreground">
          Every engagement is overseen directly by our founders — no account managers in between.
        </p>
        <ul class="mt-8 space-y-6">
          {founders.map((founder) => (
            <li class="flex items-center gap-4">
              <Image
                src={founder.avatar}
                alt={`${founder.name}, ${founder.title} of Markosh`}
                width={112}
                height={112}
                class="h-14 w-14 rounded-full border border-border object-cover"
                loading="lazy"
                format="webp"
                quality={85}
              />
              <div>
                <p class="font-semibold">{founder.name}</p>
                <p class="font-mono text-xs uppercase tracking-[0.1em] text-muted-foreground">{founder.title}</p>
              </div>
            </li>
          ))}
        </ul>
        <a href="/about" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
          Meet the team
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
