---
const profiles = [
  {
    role: 'Senior React Engineer',
    experience: '9 yrs',
    stack: ['React', 'Next.js', 'TypeScript'],
    background: 'Frontend systems for fintech and SaaS teams',
  },
  {
    role: 'AI/ML Engineer',
    experience: '7 yrs',
    stack: ['Python', 'PyTorch', 'LangChain'],
    background: 'LLM pipelines, retrieval systems, and automation',
  },
  {
    role: 'Full-Stack Engineer',
    experience: '8 yrs',
    stack: ['Node.js', 'React', 'AWS'],
    background: 'Product builds from architecture through launch',
  },
  {
    role: 'Mobile Engineer',
    experience: '6 yrs',
    stack: ['React Native', 'iOS', 'Android'],
    background: 'Consumer and internal apps across platforms',
  },
];
---

<section class="bg-background">
  <div class="container mx-auto">
    <div class="grid gap-10 lg:grid-cols-[0.82fr,1.18fr] lg:items-start">
      <div class="max-w-2xl">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — Network Snapshot</p>
        <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
          Talent shaped around <span class="text-primary">the role you need</span>
        </h2>
        <p class="mt-6 text-lg text-muted-foreground">
          Instead of sending a resume pile, Markosh narrows the bench to engineers whose stack, seniority, and communication style match the work.
        </p>
        <a href="/contact" class="mt-7 inline-flex items-center gap-2 font-semibold text-primary hover:underline">
          Describe the team gap
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      <div class="border-t border-border">
        {profiles.map((profile) => (
          <article class="grid gap-x-8 gap-y-2 border-b border-border py-6 sm:grid-cols-[1fr,auto]">
            <div>
              <h3 class="font-headline text-xl font-bold leading-snug sm:text-2xl">{profile.role}</h3>
              <p class="mt-1.5 text-sm leading-6 text-muted-foreground">{profile.background}</p>
              <p class="mt-3 font-mono text-xs uppercase tracking-[0.1em] text-muted-foreground">{profile.stack.join(' · ')}</p>
            </div>
            <div class="flex items-center gap-4 sm:flex-col sm:items-end sm:gap-2">
              <span class="inline-flex items-center gap-2 font-mono text-xs font-semibold uppercase tracking-[0.1em] text-signal">
                <span class="h-1.5 w-1.5 rounded-full bg-signal" aria-hidden="true"></span>
                Matchable
              </span>
              <span class="font-mono text-xs uppercase tracking-[0.1em] text-muted-foreground">{profile.experience}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
