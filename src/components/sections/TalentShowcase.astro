---
// Roles mirror mid-2026 demand: AI engineering is the fastest-growing title,
// fine-tuning and LLMOps are the scarcest skills, security postings keep
// climbing — with one classic product-build profile kept for balance.
const profiles = [
  {
    role: 'AI Engineer',
    experience: '2.5 yrs',
    stack: ['Python', 'LangGraph', 'RAG'],
    background: 'Agentic systems, retrieval pipelines, and LLM apps in production',
  },
  {
    role: 'ML Engineer — Fine-Tuning',
    experience: '5 yrs',
    stack: ['PyTorch', 'LoRA/QLoRA', 'DPO'],
    background: 'Model adaptation: fine-tunes, alignment, and evaluation harnesses',
  },
  {
    role: 'AI Platform Engineer',
    experience: '3 yrs',
    stack: ['Kubernetes', 'vLLM', 'LLMOps'],
    background: 'Model serving, observability, and cost and latency control',
  },
  {
    role: 'Security Engineer',
    experience: '8 yrs',
    stack: ['AWS', 'Identity', 'AppSec'],
    background: 'Cloud security, identity, and hardening AI-enabled systems',
  },
  {
    role: 'Full-Stack Product Engineer',
    experience: '9 yrs',
    stack: ['TypeScript', 'React', 'Node.js'],
    background: 'AI-enabled product builds from architecture through launch',
  },
];
---

<section class="bg-background">
  <div class="container mx-auto">
    <div class="grid gap-12 lg:grid-cols-[1fr,1.5fr] lg:items-start">
      <div class="max-w-2xl lg:sticky lg:top-28">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — Network Snapshot</p>
        <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
          Talent shaped around <span class="text-primary">the role you need</span>
        </h2>
        <p class="mt-6 text-lg leading-8 text-muted-foreground">
          Instead of sending a resume pile, Markosh narrows the bench to engineers whose stack, seniority, and communication style match the work.
        </p>
        <a href="/contact" class="mt-7 inline-flex items-center gap-2 font-semibold text-primary hover:underline">
          Describe the team gap
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      <div class="reveal-stagger border-t border-border">
        {profiles.map((profile) => (
          <article class="grid gap-x-8 gap-y-2 border-b border-border py-6 sm:grid-cols-[1fr,auto]">
            <div>
              <h3 class="font-headline text-xl font-bold leading-snug sm:text-2xl">{profile.role}</h3>
              <p class="mt-1.5 text-sm leading-6 text-muted-foreground">{profile.background}</p>
              <p class="mt-3 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">{profile.stack.join(' · ')}</p>
            </div>
            <div class="flex items-center gap-4 sm:flex-col sm:items-end sm:gap-2">
              <span class="inline-flex items-center gap-2 font-mono text-xs font-semibold uppercase tracking-[0.14em] text-signal">
                <span class="h-1.5 w-1.5 rounded-full bg-signal" aria-hidden="true"></span>
                Matchable
              </span>
              <span class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">{profile.experience}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
