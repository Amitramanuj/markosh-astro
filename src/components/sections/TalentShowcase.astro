---
// TODO(content): Replace with real (anonymized) engineer profiles from your network.
const profiles = [
  {
    role: 'Senior React Engineer',
    experience: '9 yrs',
    stack: ['React', 'Next.js', 'TypeScript'],
    background: 'Previously led frontend at a US fintech',
  },
  {
    role: 'AI/ML Engineer',
    experience: '7 yrs',
    stack: ['Python', 'PyTorch', 'LangChain'],
    background: 'Built LLM pipelines for B2B SaaS',
  },
  {
    role: 'Full-Stack Engineer',
    experience: '8 yrs',
    stack: ['Node.js', 'React', 'AWS'],
    background: 'Shipped 12+ products for US startups',
  },
  {
    role: 'Mobile Engineer',
    experience: '6 yrs',
    stack: ['React Native', 'iOS', 'Android'],
    background: 'Apps with 1M+ combined downloads',
  },
];
---

<section class="bg-secondary">
  <div class="container mx-auto">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">The Talent</p>
        <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
          Engineers you'd <span class="text-primary">hire yourself</span>
        </h2>
      </div>
      <p class="max-w-md text-lg text-muted-foreground">
        A sample of the senior engineers in our network — vetted, available, and ready to embed.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {profiles.map((profile) => (
        <article class="glass-card flex flex-col p-6">
          <div class="flex items-center justify-between">
            <span class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
              <span class="h-1.5 w-1.5 rounded-full bg-primary" aria-hidden="true"></span>
              Available
            </span>
            <span class="text-sm font-semibold text-muted-foreground">{profile.experience}</span>
          </div>
          <h3 class="mt-4 font-headline text-lg font-bold leading-snug">{profile.role}</h3>
          <p class="mt-2 flex-grow text-sm text-muted-foreground">{profile.background}</p>
          <ul class="mt-4 flex flex-wrap gap-1.5">
            {profile.stack.map((tech) => (
              <li class="rounded-full border border-border px-2.5 py-0.5 text-xs text-muted-foreground">{tech}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-muted-foreground">
      Profiles shown are representative.
      <a href="/contact" class="font-semibold text-primary hover:underline">Tell us what you need</a> and meet matched candidates within days.
    </p>
  </div>
</section>
