---
// FAQ answers an outsourcing buyer's first objections. Schema is emitted
// from index.astro (homeFaqs export) via BaseLayout's extraSchemas prop.
export const homeFaqs = [
  {
    question: 'Do your engineers work in US time zones?',
    answer: 'Yes. Every engagement guarantees at least 4 hours of EST overlap, with standups and reviews scheduled in your working hours.',
  },
  {
    question: 'Who owns the code and IP?',
    answer: 'You do. We sign your NDA before discovery, and every contract assigns full IP and source-code ownership to the client.',
  },
  {
    question: 'How does pricing work?',
    answer: 'Staff augmentation bills monthly per engineer, dedicated teams at a flat monthly rate, and projects as milestone-based fixed bids. You will get a clear quote after one discovery call.',
  },
  {
    question: 'How fast can we start?',
    answer: 'Typically within two weeks of the first call: discovery, candidate interviews, and onboarding into your tools included.',
  },
  {
    question: 'What makes Markosh an intelligence lab?',
    answer: 'AI plus research-backed execution in every aspect of an operation. AI provides the leverage; disciplined research and trained people turn it into outcomes. Because the post-AI market shifts fast, our sales and tech teams retrain continuously on new tools, data, and playbooks — that standing practice is the lab.',
  },
  {
    question: 'Can we hire both engineers and sales reps through Markosh?',
    answer: 'Yes. Markosh supports technical hiring, software delivery, AI development, sales-rep deployment, lead research, CRM operations, and combined execution pods.',
  },
];
---

<section class="bg-background">
  <div class="container mx-auto grid gap-10 lg:grid-cols-[0.75fr,1.25fr]">
    <div>
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">07 — FAQ</p>
      <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
        Questions buyers <span class="text-primary">ask first</span>
      </h2>
    </div>
    <div class="border-t border-border">
      {homeFaqs.map((faq) => (
        <details class="group border-b border-border py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-headline text-lg font-bold marker:content-none [&::-webkit-details-marker]:hidden">
            <span>{faq.question}</span>
            <svg class="h-5 w-5 shrink-0 text-primary transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <p class="mt-3 text-muted-foreground">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

