---
// The four Markosh service families, ordered by current business focus:
// Sell and Staff lead, Build and Strategy support.
// Typographic sequence: numbered rows with rules, oversized family verb,
// mono offering label, situation lead, one-line description, proof line, arrow link.
const services = [
  {
    num: '01',
    title: 'Sell',
    offering: 'B2B Sales-as-a-Service',
    situation: 'You need more qualified conversations, not more sales theory.',
    description: 'Premier B2B tech sales reps in three models — retained reps, appointment setting, and revenue-share partnerships — backed by deep contact intelligence and human-led outreach.',
    proof: 'ICP · CRM visibility · Weekly outreach QA',
    link: '/sales',
  },
  {
    num: '02',
    title: 'Staff',
    offering: 'Vetted Engineers & Specialists',
    situation: 'Your roadmap is blocked by missing technical capacity.',
    description: 'Pre-vetted engineers embedded in your team — including the scarcest pools: AI/ML, data, and security — matched to your stack and your working hours.',
    proof: 'Engineer screen · Stack match · Onboarding plan',
    link: '/services/it-staffing',
  },
  {
    num: '03',
    title: 'Build',
    offering: 'Custom Software & AI Systems',
    situation: 'You need a product or internal system shipped without hiring a full team.',
    description: 'Web, mobile, and agentic AI systems — shipped in transparent sprints, handed over with full IP.',
    proof: 'Architecture · Weekly demos · Source and documentation',
    link: '/services/custom-software-development',
  },
  {
    num: '04',
    title: 'Strategy',
    offering: 'AI Strategy & Intelligence',
    situation: 'You know AI matters, but not where it pays off first.',
    description: 'Find where AI actually pays off — mapped workflows, prioritized use cases, and a roadmap built to execute.',
    proof: 'Use-case map · Automation backlog · Execution plan',
    link: '/services/ai-strategy',
  },
];
---

<section class="bg-secondary">
  <div class="container mx-auto">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — What We Do</p>
        <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
          Four families, <span class="text-primary">one operating model</span>
        </h2>
      </div>
      <p class="max-w-md text-lg leading-8 text-muted-foreground">
        Research first, AI leverage at every step, vetted talent, managed delivery — the same lab method whether you need sales capacity, engineers, or software.
      </p>
    </div>

    <div class="reveal-stagger mt-12 border-t border-border">
      {services.map((service) => (
        <a href={service.link} class="group grid gap-x-8 gap-y-3 border-b border-border py-8 sm:py-10 md:grid-cols-[3.5rem,1fr,auto] md:items-start">
          <span class="font-mono text-sm leading-8 text-muted-foreground md:pt-2" aria-hidden="true">{service.num}</span>
          <div>
            <div class="flex flex-wrap items-baseline gap-x-5 gap-y-1">
              <h3 class="font-headline text-4xl font-bold tracking-tight transition-colors group-hover:text-primary sm:text-5xl">{service.title}</h3>
              <span class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">{service.offering}</span>
            </div>
            <p class="mt-3 max-w-xl font-medium text-foreground">{service.situation}</p>
            <p class="mt-2 max-w-xl text-muted-foreground">{service.description}</p>
            <p class="mt-4 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
              <span class="font-semibold">Proof</span> — {service.proof}
            </p>
          </div>
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-primary md:pt-3">
            Learn more
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
