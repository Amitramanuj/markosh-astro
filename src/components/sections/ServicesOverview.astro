---
const services = [
  {
    num: '01',
    icon: 'users',
    title: 'IT Staffing Services',
    description: 'Connect with our pool of vetted, top-tier tech professionals to augment your team for any project duration.',
    link: '/services',
  },
  {
    num: '02',
    icon: 'code',
    title: 'Custom Software Development',
    description: 'From concept to launch, we build scalable and secure custom web and mobile applications to meet your objectives.',
    link: '/services',
  },
  {
    num: '03',
    icon: 'brain-circuit',
    title: 'AI & Machine Learning',
    description: 'Unlock insights and automate processes with custom AI models, NLP, and computer vision solutions.',
    link: '/services',
  },
  {
    num: '04',
    icon: 'bot',
    title: 'Agentic AI Development',
    description: 'Build sophisticated AI agents that can reason, plan, and execute complex tasks to work alongside your team.',
    link: '/services',
  },
];

const getIcon = (iconName: string) => {
  const icons = {
    users: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
    </svg>`,
    code: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
    </svg>`,
    'brain-circuit': `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
    </svg>`,
    bot: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
    </svg>`
  };
  return icons[iconName as keyof typeof icons] || icons.code;
};
---

<section class="bg-background">
  <div class="container mx-auto">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Our Services</p>
        <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
          What we <span class="text-primary">build &amp; deliver</span>
        </h2>
      </div>
      <p class="max-w-md text-lg text-muted-foreground">
        From sourcing expert talent to building bespoke software, we power your digital transformation end to end.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2">
      {services.map((service) => (
        <a href={service.link} class="glass-card group relative flex flex-col p-8">
          <span class="absolute right-8 top-8 font-headline text-5xl font-bold text-muted/80 transition-colors group-hover:text-primary/20" aria-hidden="true">{service.num}</span>
          <div class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-primary/20 transition-colors group-hover:bg-primary/20">
            <Fragment set:html={getIcon(service.icon)} />
          </div>
          <h3 class="mt-6 font-headline text-2xl font-bold">{service.title}</h3>
          <p class="mt-3 flex-grow text-muted-foreground">{service.description}</p>
          <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary">
            Learn more
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>


