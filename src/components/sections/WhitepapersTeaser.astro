---
import { whitepapers } from '@/lib/whitepapers';

const featured = whitepapers.slice(0, 3);
---

<section class="bg-secondary">
  <div class="container mx-auto">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — Research</p>
        <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
          How we think about <span class="text-primary">software &amp; AI</span>
        </h2>
      </div>
      <a href="/whitepapers/" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
        All white papers
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <div class="mt-12 border-t border-border">
      {featured.map((paper) => (
        <article class="grid gap-x-8 gap-y-2 border-b border-border py-7 md:grid-cols-[14rem,1fr] md:items-baseline">
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
            {paper.category} · ~{paper.readTimeMinutes} min
          </p>
          <div>
            <h3 class="font-headline text-xl font-bold tracking-tight sm:text-2xl">
              <a href={`/whitepapers/${paper.slug}/`} class="transition-colors hover:text-primary">{paper.title}</a>
            </h3>
            <p class="mt-2 max-w-3xl text-muted-foreground">{paper.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
