---
// TODO(content): Replace these sample engagements with real client work before launch.
// Anonymized framing ("US fintech client") is fine; the numbers must be real.
const caseStudies = [
  {
    sector: 'FinTech · USA',
    title: 'Payments platform team augmentation',
    summary: 'Embedded 4 senior engineers into a US payments company to clear a 9-month feature backlog.',
    results: [
      { value: '40%', label: 'faster release cycle' },
      { value: '6 mo', label: 'backlog cleared' },
    ],
  },
  {
    sector: 'Healthcare · USA',
    title: 'HIPAA-compliant patient portal',
    summary: 'Designed and shipped a patient-facing web portal with full HIPAA-aligned data handling.',
    results: [
      { value: '3 mo', label: 'concept to launch' },
      { value: '99.9%', label: 'uptime since launch' },
    ],
  },
  {
    sector: 'SaaS · USA',
    title: 'AI document-processing pipeline',
    summary: 'Built an LLM-based extraction pipeline that replaced a manual review workflow for a B2B SaaS.',
    results: [
      { value: '85%', label: 'less manual review' },
      { value: '12x', label: 'throughput increase' },
    ],
  },
];
---

<section class="relative bg-secondary">
  <span class="section-number absolute right-4 top-8 sm:right-8" aria-hidden="true">04</span>
  <div class="container mx-auto">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Client Work</p>
        <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
          Outcomes, <span class="text-primary">not just output</span>
        </h2>
      </div>
      <p class="max-w-md text-lg text-muted-foreground">
        A sample of recent engagements with US companies across staffing and full-cycle delivery.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {caseStudies.map((study) => (
        <article class="glass-card flex flex-col p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-muted-foreground">{study.sector}</p>
          <h3 class="mt-3 font-headline text-xl font-bold">{study.title}</h3>
          <p class="mt-3 flex-grow text-muted-foreground">{study.summary}</p>
          <dl class="mt-6 grid grid-cols-2 gap-4 border-t border-border pt-6">
            {study.results.map((result) => (
              <div>
                <dd class="font-headline text-2xl font-bold text-primary">{result.value}</dd>
                <dt class="mt-0.5 text-sm text-muted-foreground">{result.label}</dt>
              </div>
            ))}
          </dl>
        </article>
      ))}
    </div>

    <!-- Editorial pull-quote — TODO(content): replace with a real, attributable client quote -->
    <figure class="mt-16 border-l-4 border-primary pl-6 sm:pl-10">
      <blockquote class="max-w-4xl font-headline text-2xl font-bold leading-snug sm:text-4xl">
        &ldquo;Markosh delivered an exceptional team that integrated seamlessly with our own. Their expertise was crucial to our project&rsquo;s success.&rdquo;
      </blockquote>
      <figcaption class="mt-6 flex items-center gap-4">
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-gradient-to-br from-primary/20 to-primary/5 font-headline font-bold">
          J
        </div>
        <div>
          <p class="font-semibold">Jane Doe</p>
          <p class="text-sm text-muted-foreground">CTO, Tech Solutions Inc.</p>
        </div>
      </figcaption>
    </figure>
  </div>
</section>
