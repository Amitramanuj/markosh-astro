---
const engagementPatterns = [
  {
    sector: 'Scale-up engineering',
    title: 'Backlog acceleration team',
    summary: 'A small embedded pod clears product backlog without forcing the client to pause roadmap work.',
    results: [
      { value: '4-6', label: 'engineers embedded' },
      { value: '2 wks', label: 'kickoff target' },
    ],
  },
  {
    sector: 'Product delivery',
    title: 'Custom platform build',
    summary: 'Discovery, architecture, implementation, and handover for a defined web or mobile product.',
    results: [
      { value: '1 lead', label: 'delivery owner' },
      { value: 'weekly', label: 'working demos' },
    ],
  },
  {
    sector: 'AI enablement',
    title: 'Workflow automation layer',
    summary: 'LLM, data, and integration work focused on replacing a slow manual business process.',
    results: [
      { value: 'API', label: 'first approach' },
      { value: 'owned', label: 'client infrastructure' },
    ],
  },
  {
    sector: 'Revenue execution',
    title: 'Outbound revenue pod',
    summary: 'A managed pod — sales rep, lead researcher, and CRM operator — running AI-assisted, human-led outreach against one defined ICP.',
    results: [
      { value: 'weekly', label: 'reporting & QA review' },
      { value: '1 ICP', label: 'per pod, by design' },
    ],
  },
];

const proofChecks = [
  'Scope written before team allocation',
  'Engineer-led technical screening',
  'Shared sprint board and weekly demos',
  'Source, documentation, and IP handed over',
];
---

<section class="bg-secondary">
  <div class="container mx-auto">
    <div class="max-w-2xl">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">04 — Engagement Patterns</p>
      <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
        Concrete ways <span class="text-primary">work gets delivered</span>
      </h2>
      <p class="mt-6 text-lg leading-8 text-muted-foreground">
        Here is how engagements actually take shape: what you can engage us for, how the team forms around it, and the delivery artifacts you walk away owning.
      </p>
    </div>

    <div class="mt-12 grid gap-12 lg:grid-cols-[1.5fr,1fr]">
      <div class="border-t border-border">
        {engagementPatterns.map((study, index) => (
          <article class="grid gap-x-8 gap-y-3 border-b border-border py-8 sm:py-10 md:grid-cols-[3.5rem,1fr]">
            <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">0{index + 1}</span>
            <div>
              <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">{study.sector}</p>
              <h3 class="mt-2 font-headline text-2xl font-bold tracking-tight sm:text-3xl">{study.title}</h3>
              <p class="mt-2 text-muted-foreground">{study.summary}</p>
              <dl class="mt-5 flex flex-wrap gap-x-12 gap-y-3">
                {study.results.map((result) => (
                  <div>
                    <dd class="font-mono text-lg font-medium tracking-tight">{result.value}</dd>
                    <dt class="mt-0.5 text-sm text-muted-foreground">{result.label}</dt>
                  </div>
                ))}
              </dl>
            </div>
          </article>
        ))}
      </div>

      <aside class="border-t-2 border-foreground pt-6 lg:sticky lg:top-28 lg:self-start">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">What stays true</p>
        <h3 class="mt-3 font-headline text-2xl font-bold">Delivery proof buyers can inspect</h3>
        <ul class="mt-6 divide-y divide-border border-b border-border">
          {proofChecks.map((item) => (
            <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
          ))}
        </ul>
        <a href="/contact" class="mt-7 inline-flex items-center gap-2 font-semibold text-primary hover:underline">
          Talk through a team plan
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </aside>
    </div>
  </div>
</section>
