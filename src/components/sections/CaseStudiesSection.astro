---
const engagementPatterns = [
  {
    sector: 'Scale-up engineering',
    title: 'Backlog acceleration team',
    summary: 'A small embedded pod clears product backlog without forcing the client to pause roadmap work.',
    results: [
      { value: '4-6', label: 'engineers embedded' },
      { value: '2 wks', label: 'kickoff target' },
    ],
  },
  {
    sector: 'Product delivery',
    title: 'Custom platform build',
    summary: 'Discovery, architecture, implementation, and handover for a defined web or mobile product.',
    results: [
      { value: '1 lead', label: 'delivery owner' },
      { value: 'weekly', label: 'working demos' },
    ],
  },
  {
    sector: 'AI enablement',
    title: 'Workflow automation layer',
    summary: 'LLM, data, and integration work focused on replacing a slow manual business process.',
    results: [
      { value: 'API', label: 'first approach' },
      { value: 'owned', label: 'client infrastructure' },
    ],
  },
];

const proofChecks = [
  'Scope written before team allocation',
  'Engineer-led technical screening',
  'Shared sprint board and weekly demos',
  'Source, documentation, and IP handed over',
];
---

<section class="relative bg-secondary">
  <span class="section-number absolute right-4 top-8 sm:right-8" aria-hidden="true">05</span>
  <div class="container mx-auto">
    <div class="grid gap-10 lg:grid-cols-[0.82fr,1.18fr] lg:items-end">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Engagement Patterns</p>
        <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
          Concrete ways <span class="text-primary">work gets delivered</span>
        </h2>
      </div>
      <p class="max-w-xl text-lg text-muted-foreground lg:justify-self-end">
        Here is how engagements actually take shape: what you can engage us for, how the team forms around it, and the delivery artifacts you walk away owning.
      </p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-[1.25fr,0.75fr]">
      <div class="space-y-4">
        {engagementPatterns.map((study, index) => (
          <article class="group grid gap-5 rounded-xl border border-border bg-card p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-lg md:grid-cols-[4rem,1fr]">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 font-headline text-lg font-bold text-primary">
              0{index + 1}
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.15em] text-muted-foreground">{study.sector}</p>
              <h3 class="mt-2 font-headline text-xl font-bold">{study.title}</h3>
              <p class="mt-2 text-muted-foreground">{study.summary}</p>
              <dl class="mt-5 grid grid-cols-2 gap-4 border-t border-border pt-5">
                {study.results.map((result) => (
                  <div>
                    <dd class="font-headline text-2xl font-bold text-primary">{result.value}</dd>
                    <dt class="mt-0.5 text-sm text-muted-foreground">{result.label}</dt>
                  </div>
                ))}
              </dl>
            </div>
          </article>
        ))}
      </div>

      <aside class="rounded-xl border border-primary/25 bg-background p-7 shadow-sm lg:sticky lg:top-28 lg:self-start">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">What stays true</p>
        <h3 class="mt-3 font-headline text-2xl font-bold">Delivery proof buyers can inspect</h3>
        <ul class="mt-6 space-y-4">
          {proofChecks.map((item) => (
            <li class="flex gap-3 text-sm leading-6 text-muted-foreground">
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-signal" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href="/contact" class="mt-7 inline-flex items-center gap-2 font-semibold text-primary hover:underline">
          Talk through a team plan
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </aside>
    </div>
  </div>
</section>
