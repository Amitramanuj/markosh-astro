---
// Role-based hiring grid — internal links into the staffing funnel.
const roles = [
  { label: 'React Developers', href: '/services/it-staffing' },
  { label: 'Node.js Developers', href: '/services/it-staffing' },
  { label: 'Python Developers', href: '/services/it-staffing' },
  { label: 'AI/ML Engineers', href: '/services/ai-development' },
  { label: 'Mobile Developers', href: '/services/it-staffing' },
  { label: 'Full-Stack Engineers', href: '/services/it-staffing' },
  { label: 'DevOps Engineers', href: '/services/it-staffing' },
  { label: 'UI/UX Designers', href: '/services/it-staffing' },
];
---

<section class="bg-secondary !py-12 sm:!py-14">
  <div class="container mx-auto flex flex-col items-center gap-6 text-center lg:flex-row lg:justify-between lg:text-left">
    <div class="max-w-xs shrink-0">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Hire by Role</p>
      <h2 class="mt-2 font-headline text-2xl font-bold tracking-tight">
        Who do you need?
      </h2>
    </div>
    <ul class="flex flex-wrap justify-center gap-2.5 lg:justify-end">
      {roles.map((role) => (
        <li>
          <a href={role.href} class="inline-block rounded-full border border-border bg-card px-5 py-1.5 font-headline text-sm transition-colors hover:border-primary/50 hover:text-primary">
            {role.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
