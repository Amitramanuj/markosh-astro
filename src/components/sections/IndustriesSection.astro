---
const industries = [
  'E-commerce',
  'SaaS',
  'Healthcare',
  'Finance',
  'Education',
  'Manufacturing',
  'FinTech',
  'Logistics',
];
---

<section class="bg-background">
  <div class="container mx-auto text-center">
    <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">Our Expertise</h2>
    <p class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
      Industries we serve
    </p>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground">
      A proven track record across a wide range of industries, delivering tailored solutions that meet unique sector challenges.
    </p>
  </div>

  <!-- Full-bleed marquee of industry pills -->
  <div class="marquee mt-12 overflow-hidden [mask-image:linear-gradient(90deg,transparent,black_10%,black_90%,transparent)]">
    <ul class="marquee-track flex w-max gap-4 pr-4" aria-label="Industries">
      {[...industries, ...industries].map((industry) => (
        <li class="whitespace-nowrap rounded-full border border-border bg-card/70 px-8 py-3 font-headline text-lg text-foreground/90 backdrop-blur transition-colors hover:border-accent/50 hover:text-accent">
          {industry}
        </li>
      ))}
    </ul>
  </div>
</section>
