---
const industries = [
  'E-commerce',
  'SaaS',
  'Healthcare',
  'Finance',
  'Education',
  'Manufacturing',
  'FinTech',
  'Logistics',
];
---

<!-- Compact band — minor section, sized accordingly -->
<section class="bg-background !py-12 sm:!py-14">
  <div class="container mx-auto flex flex-col items-center gap-6 text-center lg:flex-row lg:justify-between lg:text-left">
    <div class="max-w-xs shrink-0">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Industries</p>
      <h2 class="mt-2 font-headline text-2xl font-bold tracking-tight">
        Sector knowledge, built in
      </h2>
    </div>
    <ul class="flex flex-wrap justify-center gap-2.5 lg:justify-end" aria-label="Industries">
      {industries.map((industry) => (
        <li class="rounded-full border border-border bg-card px-5 py-1.5 font-headline text-sm transition-colors hover:border-primary/50 hover:text-primary">
          <a href="/industries">{industry}</a>
        </li>
      ))}
    </ul>
  </div>
</section>
