---
const models = [
  {
    num: '01',
    name: 'Staff Augmentation',
    tagline: 'Add engineers to your team',
    description: 'Pre-vetted engineers join your standups, your repos, and your tools. You direct the work; we guarantee the fit.',
    points: [
      'Best for: filling skill gaps fast',
      'Billing: monthly per engineer',
      'Scale up or down with 2 weeks notice',
    ],
    featured: false,
  },
  {
    num: '02',
    name: 'Dedicated Team',
    tagline: 'A squad with a lead, run by us',
    description: 'A full cross-functional team with a technical lead who owns delivery. You set priorities; we run the sprints.',
    points: [
      'Best for: ongoing product development',
      'Billing: flat monthly team rate',
      'Weekly demos and shared roadmap',
    ],
    featured: true,
  },
  {
    num: '03',
    name: 'Project Delivery',
    tagline: 'Fixed scope, fixed bid',
    description: 'A defined outcome with a defined price. We scope it, build it, and hand over documented, tested software.',
    points: [
      'Best for: well-defined builds',
      'Billing: milestone-based fixed price',
      'Full IP and source handover',
    ],
    featured: false,
  },
];
---

<section class="bg-background">
  <div class="container mx-auto">
    <div class="max-w-2xl">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">04 — Engagement Models</p>
      <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
        Work with us <span class="text-primary">your way</span>
      </h2>
      <p class="mt-6 text-lg leading-8 text-muted-foreground">
        Three ways to engage, one standard of delivery. Not sure which fits? That's what the first call is for.
      </p>
    </div>

    <div class="mt-12 border-t border-border">
      {models.map((model) => (
        <article class="grid gap-x-8 gap-y-4 border-b border-border py-8 sm:py-10 md:grid-cols-[3.5rem,1.2fr,1fr]">
          <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">{model.num}</span>
          <div>
            <div class="flex flex-wrap items-baseline gap-x-5 gap-y-1">
              <h3 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">{model.name}</h3>
              {model.featured && (
                <span class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">Most popular</span>
              )}
            </div>
            <p class="mt-2 font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">{model.tagline}</p>
            <p class="mt-3 max-w-xl text-muted-foreground">{model.description}</p>
            <a href="/contact" class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
              Discuss this model
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
          <div class="md:pt-1">
            <ul class="divide-y divide-border">
              {model.points.map((point) => (
                <li class="py-2.5 text-sm leading-6 text-muted-foreground">{point}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
