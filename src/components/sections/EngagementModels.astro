---
import Button from '@/components/ui/Button.astro';

const models = [
  {
    name: 'Staff Augmentation',
    tagline: 'Add engineers to your team',
    description: 'Pre-vetted engineers join your standups, your repos, and your tools. You direct the work; we guarantee the fit.',
    points: [
      'Best for: filling skill gaps fast',
      'Billing: monthly per engineer',
      'Scale up or down with 2 weeks notice',
    ],
    featured: false,
  },
  {
    name: 'Dedicated Team',
    tagline: 'A squad with a lead, run by us',
    description: 'A full cross-functional team with a technical lead who owns delivery. You set priorities; we run the sprints.',
    points: [
      'Best for: ongoing product development',
      'Billing: flat monthly team rate',
      'Weekly demos and shared roadmap',
    ],
    featured: true,
  },
  {
    name: 'Project Delivery',
    tagline: 'Fixed scope, fixed bid',
    description: 'A defined outcome with a defined price. We scope it, build it, and hand over documented, tested software.',
    points: [
      'Best for: well-defined builds',
      'Billing: milestone-based fixed price',
      'Full IP and source handover',
    ],
    featured: false,
  },
];
---

<section class="bg-background">
  <div class="container mx-auto">
    <div class="max-w-2xl">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">04 — Engagement Models</p>
      <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
        Work with us <span class="text-primary">your way</span>
      </h2>
      <p class="mt-6 text-lg text-muted-foreground">
        Three ways to engage, one standard of delivery. Not sure which fits? That's what the first call is for.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {models.map((model) => (
        <article class={`glass-card relative flex flex-col p-8 ${model.featured ? 'border-primary/50 shadow-[0_18px_40px_-18px_hsl(244_55%_48%/0.25)]' : ''}`}>
          {model.featured && (
            <span class="absolute -top-3 left-8 rounded-full bg-primary px-4 py-1 text-xs font-semibold uppercase tracking-wide text-primary-foreground">
              Most popular
            </span>
          )}
          <h3 class="font-headline text-2xl font-bold">{model.name}</h3>
          <p class="mt-1 text-sm font-semibold text-primary">{model.tagline}</p>
          <p class="mt-4 text-muted-foreground">{model.description}</p>
          <ul class="mt-6 flex-grow space-y-3">
            {model.points.map((point) => (
              <li class="flex items-start gap-3 text-sm text-muted-foreground">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
          <Button href="/contact" size="lg" class={`mt-8 h-11 rounded-full font-semibold ${model.featured ? 'btn-gradient' : 'border border-foreground/20 bg-transparent text-foreground hover:border-primary hover:bg-primary/5 hover:text-primary'}`}>
            Discuss this model
          </Button>
        </article>
      ))}
    </div>
  </div>
</section>
