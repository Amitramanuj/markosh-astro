---
// Homepage band for the two proof-of-capability offers — the 14-day sales rep
// experience (Sell) and the MCP pilot (Build) — promoted to a full-bleed ink
// band as the conversion moment. Judge us on work, not decks.
import Button from '@/components/ui/Button.astro';

const offers = [
  {
    eyebrow: 'Sell — 14-Day Sales Rep Experience',
    title: 'Watch a Markosh rep work your market',
    description:
      'One trained rep, AI-assisted account research, human-led outreach, and daily CRM visibility — 14 days at our investment, so you can judge execution quality before committing to any model.',
    qualifier:
      'For approved B2B companies only. One rep. One ICP. Capped activity. No appointment or closed-deal guarantee.',
    href: '/sales-rep-trial',
    cta: 'See the 14-Day Experience',
  },
  {
    eyebrow: 'Build — Your MVP, On Us',
    title: 'Your first MVP, built by us',
    description:
      'One core workflow, scoped in discovery and shipped as working software — with full source, documentation, and IP — so you can judge our engineering by using what we build.',
    qualifier:
      'For approved businesses only. One product, one core workflow. Pilot-grade build, not a production launch. No obligation afterward.',
    href: '/mvp-on-us',
    cta: 'See the MVP Offer',
  },
];
---

<section class="ink-panel">
  <div class="container mx-auto">
    <div class="max-w-3xl">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-signal sm:text-sm">06 — Proof of Capability</p>
      <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
        Judge us on work, <span class="text-signal">not decks</span>
      </h2>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-ink-foreground/80">
        Two ways to experience Markosh before committing to anything — one for revenue, one for software. Our investment, your outcomes.
      </p>
    </div>

    <div class="mt-12 grid gap-x-12 gap-y-12 lg:grid-cols-2">
      {offers.map((offer) => (
        <div class="flex flex-col border-t border-ink-foreground/20 pt-6">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-signal">{offer.eyebrow}</p>
          <h3 class="mt-3 min-h-[2.5em] font-headline text-2xl font-bold leading-snug tracking-tight sm:text-3xl">{offer.title}</h3>
          <p class="mt-4 flex-grow leading-7 text-ink-foreground/80">{offer.description}</p>
          <p class="mt-5 font-mono text-xs leading-5 text-ink-foreground/80">{offer.qualifier}</p>
          <div class="mt-6">
            <Button href={offer.href} size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              {offer.cta}
              <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
