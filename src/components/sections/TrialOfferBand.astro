---
// Homepage band for the 14-day sales rep trial — the proof object for the
// Sell family, promoted to a full-bleed ink band as the conversion moment.
import Button from '@/components/ui/Button.astro';

const qualifier =
  'For approved B2B companies only. One rep. One ICP. Capped activity. No appointment or closed-deal guarantee.';
---

<section class="ink-panel">
  <div class="container mx-auto">
    <div class="grid gap-10 lg:grid-cols-[1.25fr,0.75fr] lg:items-center">
      <div>
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-signal sm:text-sm">06 — New: B2B Sales-as-a-Service</p>
        <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
          Try a Markosh Sales Rep for <span class="text-signal">14 days at no cost</span>
        </h2>
        <p class="mt-6 max-w-2xl text-lg text-ink-foreground/70">
          One trained rep, AI-assisted account research, human-led outreach, and daily CRM visibility — so you can judge execution quality before committing to a monthly sales team.
        </p>
        <p class="mt-8 max-w-2xl border-t border-ink-foreground/20 pt-5 font-mono text-sm leading-6 text-ink-foreground/80">{qualifier}</p>
      </div>
      <div class="flex flex-wrap gap-4 lg:justify-end">
        <Button href="/sales-rep-trial" size="lg" class="btn-gradient h-12 px-8 text-base font-semibold">
          See the 14-Day Trial
          <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </Button>
      </div>
    </div>
  </div>
</section>
