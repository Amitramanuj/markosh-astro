<script is:inline>
  (() => {
    const agentId = '01K1H8Z4KAY5587YF56CR3V3F0';
    const scriptSrc = 'https://assets.taskade.com/embeds/latest/taskade-embed.min.js';
    const events = ['pointerdown', 'touchstart', 'keydown', 'scroll'];

    let hasRequestedLoad = false;
    let timerId;

    // Taskade renders its launcher inside a closed shadow root, so capture the
    // root as it's created — it's the only way to reach the launcher button.
    let agentShadowRoot = null;
    const originalAttachShadow = Element.prototype.attachShadow;
    Element.prototype.attachShadow = function (options) {
      const root = originalAttachShadow.call(this, options);
      if (this.id === `taskade-agent-popup-${agentId}`) {
        agentShadowRoot = root;
        Element.prototype.attachShadow = originalAttachShadow;
      }
      return root;
    };

    // Used by "talk to the agent" CTAs (e.g. on /contact/). Falls back to the
    // full-page chat if the launcher can't be found in time.
    window.markoshOpenAgent = () => {
      loadTaskadeWidget();
      const deadline = Date.now() + 4000;
      const tryOpen = () => {
        const launcher = agentShadowRoot?.querySelector('button');
        if (launcher) {
          launcher.click();
          return;
        }
        if (Date.now() < deadline) {
          window.setTimeout(tryOpen, 150);
          return;
        }
        window.open(`https://www.taskade.com/a/${agentId}`, '_blank', 'noopener');
      };
      tryOpen();
    };

    const initWidget = () => {
      const widget = window.TaskadeEmbed?.AgentPublicChatPopup;

      if (!widget) {
        console.warn('TaskadeEmbed not available after script load');
        return;
      }

      try {
        widget.init({
          publicAgentId: agentId,
          theme: 'light',
          preferences: {
            theme: 'light',
            hideBranding: false,
          },
        });
      } catch (error) {
        console.error('Failed to initialize Taskade widget:', error);
      }
    };

    const cleanup = () => {
      window.clearTimeout(timerId);
      events.forEach((event) => window.removeEventListener(event, loadTaskadeWidget));
    };

    function loadTaskadeWidget() {
      if (hasRequestedLoad || document.getElementById(`taskade-agent-popup-${agentId}`)) {
        return;
      }

      const existingScript = document.querySelector('script[data-taskade-embed]');
      if (existingScript) {
        hasRequestedLoad = true;
        cleanup();
        if (window.TaskadeEmbed?.AgentPublicChatPopup) {
          initWidget();
        } else {
          existingScript.addEventListener('load', initWidget, { once: true });
        }
        return;
      }

      hasRequestedLoad = true;
      cleanup();

      const script = document.createElement('script');
      script.src = scriptSrc;
      script.async = true;
      script.defer = true;
      script.dataset.taskadeEmbed = 'true';
      script.addEventListener('load', initWidget, { once: true });
      script.addEventListener('error', () => {
        console.error('Failed to load Taskade widget script');
      }, { once: true });

      document.head.appendChild(script);
    }

    timerId = window.setTimeout(loadTaskadeWidget, 3500);
    events.forEach((event) =>
      window.addEventListener(event, loadTaskadeWidget, { once: true, passive: true })
    );
  })();
</script>
