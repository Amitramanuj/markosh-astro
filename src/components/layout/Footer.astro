---
// Mega footer — dark ink closing block with the site's primary CTA.
// Social links removed until real profile URLs exist (TODO: re-add with real URLs).

const currentYear = new Date().getFullYear();

const footerLinks = {
  company: [
    { href: '/about', label: 'About Us' },
    { href: '/resources', label: 'Resources' },
    { href: '/career', label: 'Careers' },
    { href: '/contact', label: 'Contact' },
  ],
  services: [
    { href: '/services/ai-strategy', label: 'AI Strategy & Intelligence' },
    { href: '/services/custom-software-development', label: 'Software Development' },
    { href: '/services/it-staffing', label: 'IT Staffing' },
    { href: '/sales', label: 'Sales-as-a-Service' },
    { href: '/sales-rep-trial', label: '14-Day Sales Rep Trial' },
    { href: '/services', label: 'All Services' },
  ],
};
---

<footer class="ink-panel relative isolate overflow-hidden">
  <div class="absolute -top-32 left-6 right-6 -z-10 h-[24rem] rounded-full bg-primary/20 blur-[120px] sm:left-1/2 sm:right-auto sm:w-[50rem] sm:-translate-x-1/2" aria-hidden="true"></div>

  <!-- Closing CTA -->
  <div class="container mx-auto px-5 pt-20 pb-14 sm:pt-28">
    <div class="max-w-3xl">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Next Step</p>
      <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.02] tracking-tight sm:text-6xl md:text-7xl">
        Let's build <span class="text-primary">your team.</span>
      </h2>
      <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-5">
        <a href="/contact" data-astro-prefetch="hover" class="btn-gradient inline-flex h-12 items-center justify-center gap-2 whitespace-nowrap rounded-full px-8 text-base font-semibold">
          Book a Call
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a href="mailto:business@markosh.com" class="link-underline font-headline text-xl font-bold sm:text-2xl">
          business@markosh.com
        </a>
      </div>
    </div>
  </div>

  <!-- Nav columns -->
  <div class="container mx-auto px-5 pb-12">
    <div class="grid grid-cols-1 gap-8 border-t border-white/10 pt-12 md:grid-cols-3 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg viewBox="0 0 100 100" class="h-8 w-8" aria-hidden="true">
            <path
              d="M64 9 L91 49 L53 51 L48 94 L9 67 Z"
              fill="currentColor"
              stroke="currentColor"
              stroke-width="7"
              stroke-linejoin="round"
            />
          </svg>
          <span class="text-2xl font-bold font-headline">Markosh</span>
        </a>
        <p class="max-w-sm opacity-70">
          AI-first execution teams for software, talent, and revenue. Whether you need to build software, deploy AI, hire technical talent, or run outbound sales execution, Markosh gives you the intelligence layer, people, and operating rhythm to move faster.
        </p>
      </div>

      <div>
        <h3 class="font-headline font-semibold mb-4">Company</h3>
        <ul class="space-y-1">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="inline-block py-1.5 opacity-70 transition-opacity hover:opacity-100">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-headline font-semibold mb-4">Services</h3>
        <ul class="space-y-1">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="inline-block py-1.5 opacity-70 transition-opacity hover:opacity-100">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="text-sm opacity-60">
        &copy; {currentYear} Markosh PVT LTD. All rights reserved.
      </p>
    </div>
  </div>
</footer>
