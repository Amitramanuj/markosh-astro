---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/Button.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import { solutions } from '@/lib/solutions';
import type { Solution } from '@/lib/solutions';
import { generateServiceStructuredData, generateBreadcrumbStructuredData } from '@/lib/seo-utils';

export function getStaticPaths() {
  return solutions.map((solution) => ({
    params: { slug: solution.slug },
    props: { solution },
  }));
}

const { solution } = Astro.props as { solution: Solution };

const pageUrl = `https://markosh.com/solutions/${solution.slug}/`;
const extraSchemas = [
  generateServiceStructuredData(solution.name, solution.metaDescription),
  generateBreadcrumbStructuredData([
    { name: 'Home', url: 'https://markosh.com/' },
    { name: 'Solutions', url: 'https://markosh.com/solutions/' },
    { name: solution.name, url: pageUrl },
  ]),
];
---

<BaseLayout
  title={solution.metaTitle}
  description={solution.metaDescription}
  canonical={pageUrl}
  extraSchemas={extraSchemas}
>
  <Header />
  <main id="main-content">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <nav aria-label="Breadcrumb" class="text-sm text-muted-foreground">
          <ol class="flex flex-wrap items-center gap-2">
            <li><a class="hover:text-primary" href="/">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a class="hover:text-primary" href="/solutions">Solutions</a></li>
            <li aria-hidden="true">/</li>
            <li aria-current="page" class="text-foreground">{solution.name}</li>
          </ol>
        </nav>
        <div class="mt-8 max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">
            Solution — {solution.category}
          </p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            {solution.headline} <span class="text-primary">{solution.headlineAccent}</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">{solution.intro}</p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <Button href="/contact" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Book a Call
              <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
            <Button href="/solutions" size="lg" variant="outline" data-astro-prefetch="hover" class="h-12 border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
              All Solutions
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- The problem -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — The Problem</p>
          <div class="mt-6 max-w-3xl space-y-5">
            {solution.problem.map((paragraph) => (
              <p class="text-lg leading-8 text-muted-foreground">{paragraph}</p>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- How we run it -->
    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — How We Run It</p>
          <div class="mt-8 border-t border-border">
            {solution.steps.map((step) => (
              <div class="grid gap-x-8 gap-y-2 border-b border-border py-8 md:grid-cols-[3.5rem,1fr]">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">{step.num}</span>
                <div>
                  <h2 class="font-headline text-2xl font-bold tracking-tight sm:text-3xl">{step.title}</h2>
                  <p class="mt-3 max-w-3xl text-muted-foreground">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- The shape of the engagement -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">03 — The Shape of It</p>
          <dl class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {solution.shape.map((fact) => (
              <div class="border-t border-border pt-4">
                <dt class="font-headline text-3xl font-bold tracking-tight">{fact.value}</dt>
                <dd class="mt-2 text-sm text-muted-foreground">{fact.label}</dd>
              </div>
            ))}
          </dl>
          <p class="mt-10 max-w-3xl border-l-2 border-foreground/20 pl-5 text-muted-foreground">
            {solution.honestyNote}
          </p>
        </div>
      </section>
    </RevealSection>

    <!-- Proof -->
    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">04 — Proof</p>
          <div class="mt-8 max-w-3xl">
            <a href={solution.caseStudy.href} data-astro-prefetch="hover" class="group block border-t border-border pt-6">
              <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">Case study</p>
              <h2 class="mt-3 font-headline text-2xl font-bold tracking-tight group-hover:text-primary sm:text-3xl">
                {solution.caseStudy.title}
              </h2>
              <p class="mt-3 text-muted-foreground">{solution.caseStudy.description}</p>
              <span class="link-underline mt-4 inline-block font-semibold">Read the case study</span>
            </a>
            <p class="mt-8 text-sm text-muted-foreground">
              Related: <a href={solution.related.href} data-astro-prefetch="hover" class="link-underline text-foreground">{solution.related.label}</a>
            </p>
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>
