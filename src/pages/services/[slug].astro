---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/Button.astro';
import { servicePages } from '@/lib/service-pages';
import type { ServicePage } from '@/lib/service-pages';
import { generateServiceStructuredData, generateBreadcrumbStructuredData } from '@/lib/seo-utils';

export function getStaticPaths() {
  return servicePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: ServicePage };

const pageUrl = `https://markosh.com/services/${page.slug}/`;
const extraSchemas = [
  generateServiceStructuredData(page.eyebrow, page.metaDescription),
  generateBreadcrumbStructuredData([
    { name: 'Home', url: 'https://markosh.com/' },
    { name: 'Services', url: 'https://markosh.com/services/' },
    { name: page.eyebrow, url: pageUrl },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: page.faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];
---

<BaseLayout
  title={page.metaTitle}
  description={page.metaDescription}
  canonical={pageUrl}
  extraSchemas={extraSchemas}
>
  <Header />
  <main id="main-content">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <nav aria-label="Breadcrumb" class="text-sm text-muted-foreground">
          <ol class="flex flex-wrap items-center gap-2">
            <li><a class="hover:text-primary" href="/">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a class="hover:text-primary" href="/services">Services</a></li>
            <li aria-hidden="true">/</li>
            <li aria-current="page" class="text-foreground">{page.eyebrow}</li>
          </ol>
        </nav>
        <div class="mt-8 max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">{page.eyebrow}</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            {page.headline} <span class="text-primary">{page.headlineAccent}</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">{page.intro}</p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <Button href="/contact" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Book Free Consultation
              <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
            <Button href="/services" size="lg" variant="outline" data-astro-prefetch="hover" class="h-12 rounded-full border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
              All Services
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="bg-secondary">
      <div class="container mx-auto">
        <h2 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">What you get</h2>
        <dl class="mt-10 grid gap-6 sm:grid-cols-2">
          {page.benefits.map((benefit) => (
            <div class="glass-card p-7">
              <dt class="font-headline text-lg font-bold">{benefit.title}</dt>
              <dd class="mt-2 text-muted-foreground">{benefit.description}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- Process -->
    <section class="bg-background">
      <div class="container mx-auto">
        <h2 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">How it works</h2>
        <ol class="mt-10 grid gap-6 md:grid-cols-3">
          {page.process.map((item) => (
            <li class="glass-card p-7">
              <span class="font-headline text-xl font-bold text-primary" aria-hidden="true">{item.step}</span>
              <h3 class="mt-3 font-headline text-lg font-bold">{item.title}</h3>
              <p class="mt-2 text-muted-foreground">{item.description}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-secondary">
      <div class="container mx-auto max-w-3xl">
        <h2 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">Frequently asked questions</h2>
        <div class="mt-10 space-y-4">
          {page.faqs.map((faq) => (
            <details class="glass-card group p-6 open:border-primary/35">
              <summary class="cursor-pointer list-none font-headline text-lg font-bold marker:content-none [&::-webkit-details-marker]:hidden">
                {faq.question}
              </summary>
              <p class="mt-3 text-muted-foreground">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
