---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ContactForm from '@/components/islands/ContactFormCore.tsx';
import RevealSection from '@/components/layout/RevealSection.astro';
import HomeFaq, { homeFaqs } from '@/components/sections/HomeFaq.astro';
import { Toaster } from '@/components/ui/toast.tsx';

const contactMethods = [
  { label: 'Email', value: 'business@markosh.com', detail: 'General Inquiries', href: 'mailto:business@markosh.com' },
  { label: 'Phone', value: '+91 94084 94084', detail: 'Mon–Fri from 9am to 5pm', href: 'tel:+919408494084' },
  { label: 'Office', value: 'Saket, New Delhi', detail: null, href: null },
];

const expectations = [
  'A reply within one business day',
  'A 30-minute discovery call — no sales pitch',
  'We sign your NDA before any detailed discussion',
];

const extraSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: homeFaqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];
---

<BaseLayout
  title="Contact Us | Markosh"
  description="Book a 30-minute discovery call about sales pods, staffing, or a software build. We reply within one business day and sign your NDA before any detailed discussion."
  canonical="https://markosh.com/contact/"
  extraSchemas={extraSchemas}
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Contact</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Let's talk about <span class="text-primary">your roadmap</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Tell us what you are trying to ship or sell. We reply within one business day, and the first call is a 30-minute discovery conversation — not a pitch.
          </p>
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto grid gap-12 md:grid-cols-2">
          <div>
            <h2 class="font-headline text-3xl font-bold tracking-tight">Get in touch</h2>
            <div class="mt-8">
              {contactMethods.map((method) => (
                <div class="border-t border-border py-6 last:border-b">
                  <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">{method.label}</p>
                  {method.href ? (
                    <a href={method.href} class="mt-2 inline-block font-headline text-xl font-bold tracking-tight transition-colors hover:text-primary sm:text-2xl">
                      {method.value}
                    </a>
                  ) : (
                    <p class="mt-2 font-headline text-xl font-bold tracking-tight sm:text-2xl">{method.value}</p>
                  )}
                  {method.detail && <p class="mt-1 text-sm text-muted-foreground">{method.detail}</p>}
                </div>
              ))}
            </div>

            <div class="mt-8">
              <h3 class="font-headline text-lg font-bold">What happens next</h3>
              <ul class="mt-4 space-y-3">
                {expectations.map((item) => (
                  <li class="flex items-start gap-3 text-muted-foreground">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="glass-card p-8">
            <ContactForm client:load />
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="border-t border-border">
        <div class="container mx-auto grid items-center gap-8 md:grid-cols-[1fr_auto]">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Live demonstration</p>
            <h2 class="mt-4 font-headline text-3xl font-bold tracking-tight">Talk to the agent we built for ourselves</h2>
            <p class="mt-4 text-muted-foreground">
              This is the kind of system we build for clients. Ours is trained on everything Markosh does — services, engagement models, fit. Ask it anything, right now.
            </p>
            <p class="mt-2 text-sm text-muted-foreground">
              It's also the chat bubble in the corner of every page on this site.
            </p>
          </div>
          <a
            href="https://www.taskade.com/a/01K1H8Z4KAY5587YF56CR3V3F0"
            target="_blank"
            rel="noopener noreferrer"
            onclick="if (window.markoshOpenAgent) { event.preventDefault(); window.markoshOpenAgent(); }"
            class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-colors duration-200 hover:bg-primary/90 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          >
            Start a conversation
          </a>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <HomeFaq />
    </RevealSection>

    <!-- Toast container for notifications -->
    <Toaster client:load />
  </main>
  <Footer />
</BaseLayout>
