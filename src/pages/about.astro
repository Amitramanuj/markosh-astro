---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import { Lightbulb, Gem, Handshake } from '@/components/ui/icons';
import AnveshaAvatar from '@/assets/founders/anvesha.webp';
import AmitAvatar from '@/assets/founders/amit.webp';
import GrowthImage from '@/assets/about/growth.jpg';

const teamMembers = [
  { name: 'Anvesha Bhatore', title: 'Co-founder', avatar: AnveshaAvatar },
  { name: 'Amit Ramanuj', title: 'Co-founder', avatar: AmitAvatar },
];

const values = [
  { icon: Lightbulb, title: 'Innovation', description: 'We constantly seek better ways to solve problems and deliver value.' },
  { icon: Gem, title: 'Quality', description: 'We are committed to excellence and the highest standards in everything we do.' },
  { icon: Handshake, title: 'Partnership', description: 'We build lasting relationships based on trust, transparency, and mutual success.' },
];
---

<BaseLayout
  title="About Markosh"
  description="We are a team of passionate technologists and talent specialists dedicated to helping businesses thrive in the digital age."
  canonical="https://markosh.com/about/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">About</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Technologists, talent specialists, and revenue operators — <span class="text-primary">in one team</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Markosh is an AI-first execution partner. We combine AI-assisted research, vetted human talent, and managed delivery to help businesses turn strategy into execution across product, engineering, operations, and revenue.
          </p>
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto grid items-center gap-12 md:grid-cols-2">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Our Story</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-4xl">
              Built to close the <span class="text-primary">talent gap</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              Founded in 2025, Markosh was born from a desire to bridge the gap between exceptional tech talent and the companies that need them most. We saw the challenges businesses faced in building and scaling their technology teams and set out to create a better way.
            </p>
            <p class="mt-4 text-lg text-muted-foreground">
              Today, we are a trusted partner to startups and enterprises alike — and the same operating model now extends beyond engineering. Whether a client needs software built, a team staffed, an AI roadmap, or outbound sales execution, the method stays the same: research first, AI-assisted intelligence, vetted human talent, and managed delivery.
            </p>
          </div>
          <div class="relative mx-auto w-full max-w-lg">
            <div class="absolute -bottom-4 -right-4 h-full w-full rounded-2xl border border-primary/30" aria-hidden="true"></div>
            <Image
              src={GrowthImage}
              alt="A single seedling sprouting from pale sand"
              width={600}
              height={450}
              class="relative z-10 rounded-2xl shadow-xl"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Our Values</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
              What we <span class="text-primary">stand for</span>
            </h2>
          </div>
          <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
            {values.map(value => (
              <div class="glass-card p-8">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-primary/20">
                  <value.icon className="w-6 h-6" />
                </span>
                <h3 class="mt-5 font-headline text-xl font-bold">{value.title}</h3>
                <p class="mt-2 text-muted-foreground">{value.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Leadership</p>
          <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">Meet the team</h2>
          <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground">
            The passionate individuals leading Markosh forward.
          </p>
          <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-6 sm:grid-cols-2">
            {teamMembers.map((member) => (
              <div class="glass-card flex flex-col items-center p-8">
                <div class="h-32 w-32 overflow-hidden rounded-full border border-border md:h-36 md:w-36">
                  <Image
                    src={member.avatar}
                    alt={member.name}
                    width={member.avatar.width}
                    height={member.avatar.height}
                    class="h-full w-full object-cover"
                    sizes="(min-width: 768px) 144px, 128px"
                    loading="lazy"
                    format="webp"
                    quality={85}
                  />
                </div>
                <h3 class="mt-5 font-headline text-lg font-bold">{member.name}</h3>
                <p class="mt-1 text-sm font-semibold text-primary">{member.title}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>

