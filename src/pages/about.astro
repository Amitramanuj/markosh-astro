---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import AnveshaAvatar from '@/assets/founders/anvesha.webp';
import AmitAvatar from '@/assets/founders/amit.webp';
import GrowthImage from '@/assets/about/growth.jpg';

const teamMembers = [
  { name: 'Anvesha Bhatore', title: 'Co-founder', avatar: AnveshaAvatar },
  { name: 'Amit Ramanuj', title: 'Co-founder', avatar: AmitAvatar },
];

const values = [
  { num: '01', title: 'Research', description: "Every engagement starts with homework: your market, your buyers, your stack. We don't execute on guesses." },
  { num: '02', title: 'Intelligence', description: 'For us intelligence means AI plus trained human judgment. AI handles research, prep, and reporting; people handle the conversations.' },
  { num: '03', title: 'Conviction', description: 'We invest before you commit — our own time, reps, and builds. Our investment, your evaluation.' },
];
---

<BaseLayout
  title="About Markosh"
  description="Markosh is an intelligence lab with an execution arm — running B2B sales pods, engineer-vetted staffing, and software builds under one research-first method."
  canonical="https://markosh.com/about/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">About</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Technologists, talent specialists, and revenue operators — <span class="text-primary">in one team</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Markosh is the marketplace of intelligence and opportunity — an intelligence lab with an execution arm. We combine serious AI leverage with research-backed execution across revenue, talent, and software, and we retrain our teams constantly, because the post-AI market does not sit still.
          </p>
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto grid items-center gap-12 md:grid-cols-2">
          <div>
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — Our Story</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-4xl">
              Built to close the <span class="text-primary">talent gap</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              Markosh started in 2025 with a narrow observation: companies were hiring engineers off résumés and paying for it later. So we built the staffing arm around engineer-led vetting — every candidate screened by a working engineer on realistic problems before a client ever meets them.
            </p>
            <p class="mt-4 text-lg text-muted-foreground">
              Today the same operating model extends beyond engineering, and we are deliberate about the sequence: we are starting with the two engines every business needs first — B2B sales execution and technical talent — with custom software and AI systems supporting both. The long-term ambition is complete business solutions across every department of a company, delivered through one lab method: research first, AI leverage at every step, vetted human execution, and honest reporting.
            </p>
          </div>
          <div class="relative mx-auto w-full max-w-lg">
            <div class="absolute -bottom-4 -right-4 h-full w-full rounded-2xl border border-primary/30" aria-hidden="true"></div>
            <Image
              src={GrowthImage}
              alt="A single seedling sprouting from pale sand"
              width={600}
              height={450}
              class="relative z-10 rounded-2xl shadow-xl"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — Our Values</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
              What we <span class="text-primary">stand for</span>
            </h2>
          </div>
          <div class="reveal-stagger mt-14 grid grid-cols-1 gap-x-12 gap-y-10 md:grid-cols-3">
            {values.map(value => (
              <div class="border-t border-border pt-6">
                <p class="font-mono text-sm text-muted-foreground" aria-hidden="true">{value.num}</p>
                <h3 class="mt-4 font-headline text-3xl font-bold tracking-tight sm:text-4xl">{value.title}</h3>
                <p class="mt-3 leading-7 text-muted-foreground">{value.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto text-center">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">03 — Leadership</p>
          <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">Meet the team</h2>
          <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground">
            The two co-founders who run the lab day to day.
          </p>
          <div class="mx-auto mt-14 grid max-w-2xl grid-cols-1 gap-x-12 gap-y-10 sm:grid-cols-2">
            {teamMembers.map((member) => (
              <div class="flex flex-col items-center border-t border-border pt-8">
                <div class="h-32 w-32 overflow-hidden rounded-full border border-border md:h-36 md:w-36">
                  <Image
                    src={member.avatar}
                    alt={member.name}
                    width={member.avatar.width}
                    height={member.avatar.height}
                    class="h-full w-full object-cover"
                    sizes="(min-width: 768px) 144px, 128px"
                    loading="lazy"
                    format="webp"
                    quality={85}
                  />
                </div>
                <h3 class="mt-6 font-headline text-xl font-bold tracking-tight">{member.name}</h3>
                <p class="mt-2 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">{member.title}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>

