---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.published).getTime() - new Date(a.data.published).getTime()
);

const formatDate = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  title="Blog - Markosh"
  description="Field notes on B2B sales operations, technical talent, and making AI work in production — from the Markosh team."
  canonical="https://markosh.com/blog/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Blog</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Field notes from <span class="text-primary">the lab</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            How we think about sales operations, technical talent, and making AI actually stick — written from live engagements, not theory.
          </p>
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="border-t border-border">
            {posts.map((post, index) => (
              <article class="grid gap-x-8 gap-y-3 border-b border-border py-8 md:grid-cols-[3.5rem,1fr]">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">0{index + 1}</span>
                <div>
                  <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                    {post.data.category} · {formatDate(post.data.published)} · ~{post.data.readTimeMinutes} min
                  </p>
                  <h2 class="mt-2 font-headline text-2xl font-bold tracking-tight sm:text-3xl">
                    <a href={`/blog/${post.id}/`} class="transition-colors hover:text-primary">{post.data.title}</a>
                  </h2>
                  <p class="mt-2 max-w-3xl text-muted-foreground">{post.data.description}</p>
                  <a href={`/blog/${post.id}/`} class="mt-4 inline-flex items-center gap-2 font-semibold text-primary hover:underline">
                    Read the post
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>
  </main>
  <Footer />
</BaseLayout>
