---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import { whitepapers } from '@/lib/whitepapers';

const papers = [...whitepapers].sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime());
const formatDate = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
---

<BaseLayout
  title="White Papers | Markosh Research"
  description="Explore research-backed insights on AI-assisted development, engineering operations, and the economics of autonomous delivery."
  canonical="https://markosh.com/whitepapers/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Research Library</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            White papers for <span class="text-primary">engineering leaders</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Our experts synthesize market signals, platform economics, and frontline delivery lessons so you can steer AI-assisted development programs with confidence.
          </p>
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="border-t border-border">
            {papers.map((paper, index) => (
              <article class="grid gap-x-8 gap-y-3 border-b border-border py-8 md:grid-cols-[3.5rem,1fr]">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">0{index + 1}</span>
                <div>
                  <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">
                    {paper.category} · {formatDate(paper.updated ?? paper.published)} · ~{paper.readTimeMinutes} min
                  </p>
                  <h2 class="mt-2 font-headline text-2xl font-bold tracking-tight sm:text-3xl">
                    <a href={`/whitepapers/${paper.slug}/`} class="transition-colors hover:text-primary">{paper.title}</a>
                  </h2>
                  <p class="mt-2 max-w-3xl text-muted-foreground">{paper.summary}</p>
                  <a href={`/whitepapers/${paper.slug}/`} class="mt-4 inline-flex items-center gap-2 font-semibold text-primary hover:underline">
                    Read the paper
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>

