---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import Button from '@/components/ui/Button.astro';
import { CheckCircle } from '@/components/ui/icons';
import { Image } from 'astro:assets';
import careerIllustration from '../../career.png';

const upcomingRoles = [
  {
    title: 'Senior Full-Stack Engineer',
    description: 'Lead product squads across modern web stacks, cloud services, and AI-assisted tooling.',
  },
  {
    title: 'Product Designer',
    description: 'Craft intuitive experiences for global software platforms and enterprise applications.',
  },
  {
    title: 'Technical Project Manager',
    description: 'Orchestrate distributed teams and deliver critical milestones for high-growth clients.',
  },
];

const talentHighlights = [
  'Access exclusive contract and full-time engagements',
  'Collaborate with global teams building category-defining products',
  'Get early visibility into openings that match your craft',
];
---

<BaseLayout
  title="Careers at Markosh"
  description="Stay updated on upcoming career opportunities and join the Markosh talent network for exclusive roles."
  canonical="https://markosh.com/career/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-16 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto grid items-center gap-12 md:grid-cols-2">
        <div class="order-2 md:order-1">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Careers</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Do your best work, <span class="text-primary">anywhere</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            We are expanding our roster of engineers, designers, and product leaders. Join the Markosh talent network to get notified when new openings go live and match your expertise.
          </p>
          <ul class="mt-6 space-y-3">
            {talentHighlights.map((item) => (
              <li class="flex items-start gap-3 text-muted-foreground">
                <CheckCircle className="mt-1 h-5 w-5 shrink-0 text-primary" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <Button href="/contact" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Join the Talent Network
            </Button>
            <Button href="mailto:talent@markosh.com" size="lg" variant="outline" class="h-12 rounded-full border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
              Email Our Team
            </Button>
          </div>
        </div>
        <div class="relative order-1 mx-auto w-full max-w-lg md:order-2">
          <div class="absolute -bottom-4 -right-4 h-full w-full rounded-2xl border border-primary/30" aria-hidden="true"></div>
          <Image
            src={careerIllustration}
            alt="Professionals exploring career opportunities at Markosh"
            width={620}
            height={480}
            class="relative z-10 w-full rounded-2xl shadow-xl"
            loading="eager"
            format="webp"
            quality={85}
          />
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Open Soon</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
              Upcoming <span class="text-primary">roles</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              These highlighted opportunities are in planning and will open soon. Express your interest now to be among the first to interview.
            </p>
          </div>
          <div class="mt-12 grid gap-6 md:grid-cols-3">
            {upcomingRoles.map((role) => (
              <article class="glass-card flex flex-col p-8">
                <p class="text-xs font-semibold uppercase tracking-[0.15em] text-primary">Opening soon</p>
                <h3 class="mt-3 font-headline text-xl font-bold">{role.title}</h3>
                <p class="mt-3 text-muted-foreground">{role.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto grid items-center gap-12 md:grid-cols-2">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Talent Network</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-4xl">
              How it <span class="text-primary">works</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              Share your portfolio, preferred roles, and availability. Our team will keep you posted on tailored opportunities, interview timelines, and curated updates.
            </p>
            <p class="mt-4 text-muted-foreground">
              We respect your time; only relevant roles hit your inbox, and you can opt out anytime.
            </p>
          </div>
          <div class="glass-card p-8">
            <h3 class="font-headline text-2xl font-bold">Be first in line</h3>
            <p class="mt-3 text-muted-foreground">
              Send us a quick note with your latest CV or portfolio link and the types of challenges you love solving.
            </p>
            <div class="mt-6 flex flex-col gap-4 sm:flex-row">
              <Button href="mailto:talent@markosh.com" size="lg" class="btn-gradient h-12 px-8 font-semibold">
                Share My Profile
              </Button>
              <Button href="/contact" size="lg" variant="outline" data-astro-prefetch="hover" class="h-12 rounded-full border-foreground/20 bg-transparent px-8 hover:border-primary hover:bg-primary/5 hover:text-primary">
                Schedule a Call
              </Button>
            </div>
          </div>
        </div>
      </section>
    </RevealSection>
  </main>
  <Footer />
</BaseLayout>
