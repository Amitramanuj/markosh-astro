---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import Button from '@/components/ui/Button.astro';
import { CheckCircle } from '@/components/ui/icons';

const talentHighlights = [
  'Your work is reviewed by a practitioner in your field — never a keyword filter or an ATS',
  'Real client engagements, contract and full-time, across sales, engineering, and product',
  'Human-led, AI-assisted work: AI handles research, prep, and reporting — you handle the judgment',
];

const practiceAreas = [
  {
    num: '01',
    title: 'Sell',
    description: 'Sales reps and researchers who run real conversations. AI does the research and reporting — people do the selling.',
  },
  {
    num: '02',
    title: 'Staff',
    description: 'Engineers who can pass a screen run by another engineer. Placed with clients on contract or full-time.',
  },
  {
    num: '03',
    title: 'Build',
    description: 'Full-stack engineers, designers, and product managers who ship working software, not slide decks.',
  },
  {
    num: '04',
    title: 'Strategy',
    description: 'Analysts and operators who turn market research into plans a client can execute on Monday.',
  },
];

const vettingSteps = [
  {
    stage: 'Work review',
    detail: "A practitioner in your field reviews what you've built, sold, or shipped. No resume scoring, no buzzword matching.",
  },
  {
    stage: 'Skills deep-dive',
    detail: 'A working interview on the real decisions behind your work — architecture, deals, trade-offs — not trivia.',
  },
  {
    stage: 'Paid test project',
    detail: "A realistic task evaluated for quality, speed, and collaboration. We pay for your time — we don't ask for free work.",
  },
  {
    stage: 'Join the network',
    detail: "Pass, and you're in. We only introduce people we would put on our own projects.",
  },
];
---

<BaseLayout
  title="Careers at Markosh"
  description="Markosh hires for proof, not pedigree. Join a skills-vetted network of sales reps, engineers, builders, and strategists working on real client engagements."
  canonical="https://markosh.com/career/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-16 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Careers</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            We hire for proof, <span class="text-primary">not pedigree</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Show us what you can build, sell, or ship. That's the whole application. Markosh runs a skills-vetted network of sales reps, engineers, builders, and strategists — and when a role opens, the network hears first.
          </p>
          <ul class="mt-6 space-y-3">
            {talentHighlights.map((item) => (
              <li class="flex items-start gap-3 text-muted-foreground">
                <CheckCircle className="mt-1 h-5 w-5 shrink-0 text-primary" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <Button href="/contact" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Join the Talent Network
            </Button>
            <Button href="mailto:talent@markosh.com" size="lg" variant="outline" class="h-12 border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
              Email Our Team
            </Button>
          </div>
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — What We Hire For</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
              Four practices, <span class="text-primary">one bar</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              We don't post ghost listings. These are the four areas we hire into — join the network and you're first in line when a real role opens.
            </p>
          </div>
          <div class="mt-14 grid gap-x-12 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
            {practiceAreas.map((area) => (
              <article class="border-t border-border pt-6">
                <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">{area.num}</p>
                <h3 class="mt-4 font-headline text-2xl font-bold tracking-tight">{area.title}</h3>
                <p class="mt-3 leading-7 text-muted-foreground">{area.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — How We Vet</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-5xl">
              What to <span class="text-primary">expect</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              The same funnel our clients trust is the one you go through — and it's built to respect your time as much as theirs.
            </p>
          </div>
          <ol class="mt-14 grid gap-x-12 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
            {vettingSteps.map((step, index) => (
              <li class="border-t border-border pt-6">
                <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Step {index + 1}</p>
                <h3 class="mt-4 font-headline text-2xl font-bold tracking-tight">{step.stage}</h3>
                <p class="mt-3 leading-7 text-muted-foreground">{step.detail}</p>
              </li>
            ))}
          </ol>
          <p class="mt-12 text-muted-foreground">
            Why we work this way: <a href="/blog/skills-based-vetting-over-resume-screening/" class="font-semibold text-primary underline underline-offset-4 hover:opacity-80" data-astro-prefetch="hover">Skills-based vetting over resume screening</a>
          </p>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto grid items-center gap-12 md:grid-cols-2">
          <div>
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">03 — Talent Network</p>
            <h2 class="mt-3 font-headline text-3xl font-bold tracking-tight sm:text-4xl">
              How it <span class="text-primary">works</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              Share your portfolio, the roles you want, and your availability. When something genuinely matches, you hear from a person — not a drip campaign.
            </p>
            <p class="mt-4 text-muted-foreground">
              No newsletters, no fake urgency. Only relevant roles hit your inbox, and you can opt out anytime.
            </p>
          </div>
          <div class="glass-card p-8">
            <h3 class="font-headline text-2xl font-bold">Get on the list</h3>
            <p class="mt-3 text-muted-foreground">
              Email your CV or portfolio link and a line about the work you want to do. That's it — the work does the talking from there.
            </p>
            <div class="mt-6 flex flex-col gap-4 sm:flex-row">
              <Button href="mailto:talent@markosh.com" size="lg" class="btn-gradient h-12 px-8 font-semibold">
                Share My Profile
              </Button>
              <Button href="/contact" size="lg" variant="outline" data-astro-prefetch="hover" class="h-12 border-foreground/20 bg-transparent px-8 hover:border-primary hover:bg-primary/5 hover:text-primary">
                Schedule a Call
              </Button>
            </div>
          </div>
        </div>
      </section>
    </RevealSection>
  </main>
  <Footer />
</BaseLayout>
