---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import { generateArticleStructuredData, generateBreadcrumbStructuredData } from '@/lib/seo-utils';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ data }) => !data.draft);
  return studies.map((study) => ({ params: { slug: study.id }, props: { study } }));
}

const { study } = Astro.props as { study: CollectionEntry<'case-studies'> };
const { Content } = await render(study);

const pageUrl = `https://markosh.com/case-studies/${study.id}/`;
const extraSchemas = [
  generateArticleStructuredData({
    title: study.data.title,
    description: study.data.description,
    url: pageUrl,
    publishedTime: study.data.published,
    section: 'Case Studies',
  }),
  generateBreadcrumbStructuredData([
    { name: 'Home', url: 'https://markosh.com/' },
    { name: 'Case Studies', url: 'https://markosh.com/case-studies/' },
    { name: study.data.title, url: pageUrl },
  ]),
];
---

<BaseLayout
  title={study.data.title}
  description={study.data.description}
  canonical={pageUrl}
  type="article"
  publishedTime={study.data.published}
  section="Case Studies"
  extraSchemas={extraSchemas}
>
  <Header />
  <main id="main-content">
    <section class="relative isolate overflow-hidden pt-10 pb-8 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <nav aria-label="Breadcrumb" class="text-sm text-muted-foreground">
          <ol class="flex flex-wrap items-center gap-2">
            <li><a class="hover:text-primary" href="/">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a class="hover:text-primary" href="/case-studies/">Case Studies</a></li>
            <li aria-hidden="true">/</li>
            <li aria-current="page" class="text-foreground">{study.data.title}</li>
          </ol>
        </nav>
        <div class="mt-8 max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">
            {study.data.sector} · {study.data.family}
          </p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl">
            {study.data.title}
          </h1>
          <dl class="mt-8 flex flex-wrap gap-x-12 gap-y-3">
            {study.data.results.map((result) => (
              <div>
                <dd class="font-mono text-lg font-medium tracking-tight">{result.value}</dd>
                <dt class="mt-0.5 text-sm text-muted-foreground">{result.label}</dt>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <article class="article-body max-w-3xl">
            <Content />
          </article>
          <div class="mt-12 flex max-w-3xl flex-wrap items-center gap-x-10 gap-y-4 border-t border-border pt-8">
            <a href="/case-studies/" class="inline-flex items-center gap-2 font-semibold text-primary hover:underline">
              All case studies
              <svg class="h-4 w-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a href="/contact" class="inline-flex items-center gap-2 font-semibold text-primary hover:underline">
              Talk through a similar engagement
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>
    </RevealSection>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  /* Markdown body styling — mirrors whitepaper article rhythm */
  .article-body :is(h2) {
    margin-top: 2.5rem;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .article-body :is(h3) {
    margin-top: 2rem;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
  }
  .article-body p {
    margin-top: 1rem;
    line-height: 1.75;
  }
  .article-body > p:first-child {
    margin-top: 0;
    font-size: 1.125rem;
    color: hsl(var(--foreground));
  }
  .article-body em {
    color: hsl(var(--muted-foreground));
  }
  .article-body ul,
  .article-body ol {
    margin-top: 1rem;
    padding-left: 1.5rem;
    display: grid;
    gap: 0.5rem;
    line-height: 1.7;
  }
  .article-body ul { list-style: disc; }
  .article-body ol { list-style: decimal; }
  .article-body strong { font-weight: 600; }
  .article-body a {
    color: hsl(var(--primary));
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
