---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import EngagementModels from '@/components/sections/EngagementModels.astro';
import Button from '@/components/ui/Button.astro';
import { generateServiceStructuredData, generateBreadcrumbStructuredData } from '@/lib/seo-utils';

const services = [
  {
    title: 'AI Strategy & Intelligence',
    link: '/services/ai-strategy',
    description: 'Before you invest in AI tools or custom development, we help you identify where AI can create real business value — and build an execution roadmap your team can actually implement.',
    features: [
      'AI opportunity and workflow automation mapping',
      'Data and AI readiness assessment',
      'Use-case prioritization and build vs. buy guidance',
      '30/60/90-day execution roadmap',
    ],
  },
  {
    title: 'IT Staffing Services',
    link: '/services/it-staffing',
    description: 'Finding the right technical talent is crucial. We connect you with highly skilled, pre-vetted professionals who can seamlessly integrate into your team.',
    features: [
      'Access to a pre-vetted talent pool',
      'Flexible engagement models',
      'Rapid team augmentation',
      'Cultural and technical fit matching',
    ],
  },
  {
    title: 'Custom Software Development',
    link: '/services/custom-software-development',
    description: 'We turn your ideas into high-quality software. Our full-cycle development services cover everything from strategy and design to development and deployment.',
    features: [
      'End-to-end custom application development',
      'Agile and transparent workflow',
      'Scalable and secure architecture',
      'Ongoing support and maintenance',
    ],
  },
  {
    title: 'Mobile & Web Development',
    link: '/services/custom-software-development',
    description: 'We design and build beautiful, responsive, and high-performing websites and mobile applications for all platforms.',
    features: [
      'React & Next.js web applications',
      'Native iOS & Android development',
      'Cross-platform solutions (React Native)',
      'UI/UX design and prototyping',
    ],
  },
  {
    title: 'AI & Machine Learning',
    link: '/services/ai-development',
    description: 'Leverage the power of artificial intelligence to unlock new insights, automate processes, and create intelligent applications that drive business value.',
    features: [
      'Custom AI model development',
      'Natural Language Processing (NLP)',
      'Computer Vision and Image Analysis',
      'Predictive analytics and data science',
    ],
  },
  {
    title: 'Agentic AI Development',
    link: '/services/ai-development',
    description: 'Build sophisticated AI agents that can reason, plan, and execute complex tasks. We create autonomous systems that work alongside your team.',
    features: [
      'Custom AI agent design & implementation',
      'Large Language Model (LLM) integration',
      'Multi-agent systems and simulations',
      'Tool use and function calling for agents',
    ],
  },
  {
    title: 'Cloud & DevOps',
    link: '/contact',
    description: 'Optimize your infrastructure with our cloud and DevOps expertise. We help you build scalable, resilient systems and accelerate your development lifecycle.',
    features: [
      'Cloud migration and strategy (AWS, GCP, Azure)',
      'CI/CD pipeline implementation',
      'Infrastructure as Code (IaC)',
      'Performance monitoring and optimization',
    ],
  },
  {
    title: 'B2B Sales-as-a-Service',
    link: '/sales',
    description: 'Trained sales reps, lead researchers, and revenue operators who use AI-assisted research and human-led outreach to help B2B companies create more qualified sales conversations.',
    features: [
      'Dedicated sales reps and managed revenue pods',
      'AI-assisted account research and lead prioritization',
      'Compliance-aware, human-led outreach',
      '14-day sales rep trial for approved B2B companies',
    ],
  },
];

const techStack = [
  'React', 'Next.js', 'Node.js', 'Python', 'Genkit', 'LangChain', 'TensorFlow', 'PyTorch', 'Java', 'Go', 'iOS', 'Android', 'AWS', 'GCP', 'Azure', 'Docker', 'Kubernetes'
];

const process = [
  { step: '01', title: 'Discovery', description: 'A detailed exploration of project goals, technical requirements, and business objectives to ensure a solid foundation.' },
  { step: '02', title: 'Strategy', description: 'A concrete plan: team shape, milestones, architecture decisions, and the metrics we will be judged on.' },
  { step: '03', title: 'Execution', description: 'Two-week sprints with demos at every step. You see working software early and direct the roadmap.' },
  { step: '04', title: 'Launch & Support', description: 'Deployment to your infrastructure, full documentation, and ongoing support on your terms.' },
];

const extraSchemas = [
  ...services.map((service) => generateServiceStructuredData(service.title, service.description)),
  generateBreadcrumbStructuredData([
    { name: 'Home', url: 'https://markosh.com/' },
    { name: 'Services', url: 'https://markosh.com/services/' }
  ])
];
---

<BaseLayout
  title="Our Services - Markosh"
  description="Four connected service families: AI Strategy & Intelligence, custom software development, IT staffing, and B2B Sales-as-a-Service."
  canonical="https://markosh.com/services/"
  extraSchemas={extraSchemas}
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-4xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Our Services</p>
          <h1 class="mt-5 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
            Strategy, build, staff, and sell — <span class="text-primary">one execution partner</span>
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-muted-foreground">
            Four connected service families under one operating model: research first, AI-assisted intelligence, vetted human talent, and managed execution with measurable outcomes.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <Button href="/contact" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Book a Call
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Typographic service index -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — Services</p>
          <div class="mt-8 border-t border-border">
            {services.map((service, index) => (
              <div class="grid gap-x-8 gap-y-4 border-b border-border py-10 sm:py-12 md:grid-cols-[3.5rem,1.2fr,1fr]">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">0{index + 1}</span>
                <div>
                  <h2 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">{service.title}</h2>
                  <p class="mt-3 max-w-xl text-muted-foreground">{service.description}</p>
                  <a href={service.link} class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
                    Learn more
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
                <ul class="divide-y divide-border md:pt-1">
                  {service.features.map((feature) => (
                    <li class="py-2.5 text-sm leading-6 text-muted-foreground">{feature}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — Tooling</p>
          <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">Our technology stack</h2>
          <p class="mt-5 max-w-2xl text-lg text-muted-foreground">
            We work with a wide range of modern technologies to build robust and scalable solutions.
          </p>
          <p class="mt-10 max-w-4xl border-t border-border pt-6 font-mono text-sm leading-8 text-muted-foreground">
            {techStack.join(' · ')}
          </p>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">03 — Process</p>
            <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
              Transparent from <span class="text-primary">day one</span>
            </h2>
          </div>
          <ol class="mt-12 grid gap-x-10 gap-y-10 md:grid-cols-2 lg:grid-cols-4">
            {process.map((item) => (
              <li class="border-t border-border pt-5">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">{item.step}</span>
                <h3 class="mt-3 font-headline text-lg font-bold">{item.title}</h3>
                <p class="mt-2 text-sm text-muted-foreground">{item.description}</p>
              </li>
            ))}
          </ol>
        </div>
      </section>
    </RevealSection>

    <RevealSection>
      <EngagementModels />
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>
