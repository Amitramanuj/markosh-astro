---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import FadeInSection from '@/components/islands/FadeInSection.tsx';
import WhitepapersTeaser from '@/components/sections/WhitepapersTeaser.astro';
import CtaSection from '@/components/sections/CtaSection.astro';
import { FileText, Newspaper } from "@/components/ui/icons";
---

<BaseLayout
  title="Resources - Markosh"
  description="Explore our insights, research, and success stories."
  canonical="https://markosh.com/resources/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Resources</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Insights, research, <span class="text-primary">and results</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Explore our insights, research, and success stories.
          </p>
        </div>
      </div>
    </section>

    <FadeInSection client:visible>
      <WhitepapersTeaser />
    </FadeInSection>

    <FadeInSection client:visible>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="grid gap-6 md:grid-cols-2">
            <div class="glass-card p-8">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-primary/20">
                <FileText className="w-6 h-6" />
              </span>
              <h2 class="mt-5 font-headline text-xl font-bold">Case Studies</h2>
              <p class="mt-2 text-muted-foreground">
                Real-world examples of how we've helped our clients succeed. Coming soon — check back to see our success stories.
              </p>
            </div>
            <div class="glass-card p-8">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-primary/20">
                <Newspaper className="w-6 h-6" />
              </span>
              <h2 class="mt-5 font-headline text-xl font-bold">Blog</h2>
              <p class="mt-2 text-muted-foreground">
                Articles on software development, IT staffing, and business growth. Launching soon.
              </p>
            </div>
          </div>
        </div>
      </section>
    </FadeInSection>

    <CtaSection />
  </main>
  <Footer />
</BaseLayout>
