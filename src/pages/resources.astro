---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import WhitepapersTeaser from '@/components/sections/WhitepapersTeaser.astro';

const upcoming = [
  {
    title: 'Case Studies',
    description: "Real-world examples of how we've helped our clients succeed. Coming soon - check back to see our success stories.",
  },
  {
    title: 'Blog',
    description: 'Articles on software development, IT staffing, and business growth. Launching soon.',
  },
];
---

<BaseLayout
  title="Resources - Markosh"
  description="Explore our insights, research, and success stories."
  canonical="https://markosh.com/resources/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Resources</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Insights, research, <span class="text-primary">and results</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Explore our insights, research, and success stories.
          </p>
        </div>
      </div>
    </section>

    <RevealSection>
      <WhitepapersTeaser />
    </RevealSection>

    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="grid gap-x-12 gap-y-10 md:grid-cols-2">
            {upcoming.map((item) => (
              <div class="border-t border-border pt-6">
                <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Coming Soon</p>
                <h2 class="mt-4 font-headline text-3xl font-bold tracking-tight">{item.title}</h2>
                <p class="mt-3 leading-7 text-muted-foreground">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>

