---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/Button.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import { generateServiceStructuredData, generateBreadcrumbStructuredData } from '@/lib/seo-utils';

const metaTitle = 'The 14-Day Sales Rep Experience';
const metaDescription =
  'Approved B2B companies get a trained Markosh sales rep for 14 days — at our investment — to evaluate research quality, outreach discipline, and CRM visibility.';
const pageUrl = 'https://markosh.com/sales-rep-trial/';

const qualifier =
  'For approved B2B companies only. One rep. One ICP. Capped activity. No appointment or closed-deal guarantee.';

const proves = [
  'Research quality',
  'ICP understanding',
  'Rep communication',
  'Account preparation',
  'Outreach discipline',
  'CRM note quality',
  'Prospect feedback',
  'Daily visibility',
];

const included = [
  'One trained remote sales rep',
  'One defined ICP and one approved offer',
  'One target market or territory',
  'ICP and offer review',
  'AI-assisted account research',
  'Talk-track or script setup',
  'Controlled human-led outreach',
  'Daily notes or CRM-style reporting',
  'End-of-trial recommendation',
];

const excluded = [
  'Guaranteed appointments, closed deals, or revenue',
  'Unlimited calling or unlimited lead research',
  'AI voice outreach or robocalling',
  'Work outside the agreed ICP',
  'Unapproved messaging',
  'Closing deals on your behalf',
];

const eligible = [
  'A B2B offer with a clear target customer',
  'A meaningful average deal value',
  'A founder, AE, or closer available to take calls',
  'A defined geographic or industry focus',
  'A legitimate business website and a real follow-up process',
  'Willingness to approve ICP, messaging, and compliance rules',
];

const notEligible = [
  'No clear ICP or an untested offer',
  'Average deal value too low to justify outbound',
  'No one available to take sales conversations',
  'Expecting guaranteed revenue in 14 days',
  'Wanting spam-style mass outreach',
  'Consumer or high-risk offers with extra compliance exposure',
];

const faqs = [
  {
    question: 'Do you guarantee appointments during the trial?',
    answer: 'No. The trial is designed to show execution quality and market feedback. Appointments may happen, but they are not guaranteed.',
  },
  {
    question: 'Why not offer the first appointment for free?',
    answer: 'Appointment difficulty varies by niche, buyer seniority, deal size, market timing, and your offer. A controlled sales-rep trial is more transparent and avoids open-ended delivery risk on both sides.',
  },
  {
    question: 'What happens after the 14 days?',
    answer: 'You get an end-of-engagement recommendation: what the rep learned, what the market said, and whether a retained dedicated rep, an appointment-setting program, or a revenue-share partnership makes sense. No obligation either way.',
  },
  {
    question: 'Why do you approve companies before starting?',
    answer: 'The trial only proves anything if the fundamentals are in place: a clear ICP, a real offer, and someone to take qualified conversations. Approval protects your two weeks as much as ours.',
  },
];

const extraSchemas = [
  generateServiceStructuredData('14-Day Sales Rep Experience', metaDescription),
  generateBreadcrumbStructuredData([
    { name: 'Home', url: 'https://markosh.com/' },
    { name: 'B2B Sales-as-a-Service', url: 'https://markosh.com/sales/' },
    { name: '14-Day Sales Rep Experience', url: pageUrl },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical={pageUrl}
  extraSchemas={extraSchemas}
>
  <Header />
  <main id="main-content">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16 lg:pb-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <nav aria-label="Breadcrumb" class="text-sm text-muted-foreground">
          <ol class="flex flex-wrap items-center gap-2">
            <li><a class="hover:text-primary" href="/">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a class="hover:text-primary" href="/sales">Sales</a></li>
            <li aria-current="page" class="text-foreground">14-Day Experience</li>
          </ol>
        </nav>
        <div class="mt-8 max-w-4xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">The 14-Day Sales Rep Experience</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
            Fourteen days with a Markosh rep — <span class="text-primary">our investment, your evaluation</span>
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-muted-foreground">
            This is not a freemium teaser. It is an audition, at our expense: one trained rep works one ICP and one approved offer so you can judge research quality, communication, outreach discipline, and CRM visibility the only way that means anything — by watching real work in your market.
          </p>
          <p class="mt-8 max-w-2xl border-y border-border py-4 font-mono text-sm leading-6 text-foreground">
            {qualifier}
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <Button href="/contact?outcome=sales-trial" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Apply for the 14-Day Experience
              <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
            <Button href="/sales" size="lg" variant="outline" data-astro-prefetch="hover" class="h-12 border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
              All Sales Services
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- What the trial proves -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — Purpose</p>
            <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
              The trial proves <span class="text-primary">execution quality</span>, not vanity metrics
            </h2>
            <p class="mt-6 text-lg leading-8 text-muted-foreground">
              Fourteen days is enough to judge how we work — not enough to promise pipeline. Here is what you will be able to evaluate:
            </p>
          </div>
          <ul class="mt-12 grid grid-cols-2 gap-x-8 gap-y-6 md:grid-cols-4">
            {proves.map((item) => (
              <li class="border-t border-border pt-4 font-headline text-base font-bold">{item}</li>
            ))}
          </ul>
        </div>
      </section>
    </RevealSection>

    <!-- Included / excluded -->
    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — Scope</p>
          <div class="mt-12 grid gap-x-12 gap-y-10 md:grid-cols-2">
            <div>
              <h2 class="border-b-2 border-foreground pb-3 font-headline text-2xl font-bold">What the trial includes</h2>
              <ul class="divide-y divide-border">
                {included.map((item) => (
                  <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                ))}
              </ul>
            </div>
            <div>
              <h2 class="border-b-2 border-foreground pb-3 font-headline text-2xl font-bold">What it deliberately excludes</h2>
              <ul class="divide-y divide-border">
                {excluded.map((item) => (
                  <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                ))}
              </ul>
              <p class="mt-6 border-t border-border pt-5 text-sm leading-6 text-muted-foreground">
                These limits keep the trial honest. Anyone promising guaranteed meetings in two weeks is guessing with your brand.
              </p>
            </div>
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- Eligibility (ink panel) -->
    <RevealSection>
      <section class="ink-panel">
        <div class="container mx-auto">
          <div class="max-w-3xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-signal sm:text-sm">03 — Eligibility</p>
            <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
              Approved companies <span class="text-signal">only</span>
            </h2>
            <p class="mt-6 text-lg leading-8 text-ink-foreground/70">
              We review every application. The trial works when the fundamentals are in place — and wastes everyone's time when they are not.
            </p>
          </div>
          <div class="mt-12 grid gap-x-12 gap-y-10 md:grid-cols-2">
            <div>
              <h3 class="border-b-2 border-ink-foreground/60 pb-3 font-headline text-lg font-bold text-signal">You qualify if you have</h3>
              <ul class="divide-y divide-ink-foreground/15">
                {eligible.map((item) => (
                  <li class="py-3 text-sm leading-6 text-ink-foreground/70">{item}</li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="border-b-2 border-ink-foreground/60 pb-3 font-headline text-lg font-bold">Not a fit right now</h3>
              <ul class="divide-y divide-ink-foreground/15">
                {notEligible.map((item) => (
                  <li class="py-3 text-sm leading-6 text-ink-foreground/70">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- FAQ + apply -->
    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">04 — FAQ</p>
          <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">Frequently asked questions</h2>
          <div class="mt-12 border-t border-border">
            {faqs.map((faq) => (
              <details class="group border-b border-border py-6">
                <summary class="cursor-pointer list-none font-headline text-lg font-bold marker:content-none [&::-webkit-details-marker]:hidden">
                  {faq.question}
                </summary>
                <p class="mt-3 text-muted-foreground">{faq.answer}</p>
              </details>
            ))}
          </div>
          <div class="mt-12">
            <Button href="/contact?outcome=sales-trial" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Apply for the 14-Day Experience
            </Button>
            <p class="mt-5 font-mono text-sm leading-6 text-muted-foreground">{qualifier}</p>
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>
