---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import TalentShowcase from '@/components/sections/TalentShowcase.astro';
import ServicesOverview from '@/components/sections/ServicesOverview.astro';
import EngagementModels from '@/components/sections/EngagementModels.astro';
import VettingProcess from '@/components/sections/VettingProcess.astro';
import CaseStudiesSection from '@/components/sections/CaseStudiesSection.astro';
import TrialOfferBand from '@/components/sections/TrialOfferBand.astro';
import TrustSection from '@/components/sections/TrustSection.astro';
import RolesGrid from '@/components/sections/RolesGrid.astro';
import HomeFaq, { homeFaqs } from '@/components/sections/HomeFaq.astro';
import FadeInSection from '@/components/islands/FadeInSection.tsx';
import { pageSEO } from '@/lib/seo-utils';

// FAQ rich-result schema, built from the same content rendered below.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout {...pageSEO.home} extraSchemas={[faqSchema]}>
  <Header />
  <main id="main-content">
    <!-- Hero section loads immediately for LCP -->
    <FadeInSection client:load>
      <HeroSection />
    </FadeInSection>

    <!-- The product: vetted talent -->
    <FadeInSection client:visible>
      <TalentShowcase />
    </FadeInSection>

    <!-- What you can buy and how -->
    <FadeInSection client:visible>
      <ServicesOverview />
    </FadeInSection>
    <FadeInSection client:idle>
      <EngagementModels />
    </FadeInSection>

    <!-- Why believe us -->
    <FadeInSection client:idle>
      <VettingProcess />
    </FadeInSection>
    <FadeInSection client:idle>
      <CaseStudiesSection />
    </FadeInSection>

    <!-- The Sell family's proof object: the 14-day trial -->
    <FadeInSection client:idle>
      <TrialOfferBand />
    </FadeInSection>

    <FadeInSection client:idle>
      <TrustSection />
    </FadeInSection>

    <!-- Answer the buyer's first objections -->
    <FadeInSection client:idle>
      <HomeFaq />
    </FadeInSection>

    <!-- Internal links into the hiring funnel -->
    <FadeInSection client:idle>
      <RolesGrid />
    </FadeInSection>
  </main>
  <Footer />
</BaseLayout>
