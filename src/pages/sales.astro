---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/Button.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import { generateServiceStructuredData, generateBreadcrumbStructuredData } from '@/lib/seo-utils';

const metaTitle = 'B2B Sales-as-a-Service for Tech Companies';
const metaDescription =
  'B2B tech sales reps in three models — retained reps, appointment setting, and revenue-share partnerships — human-led and backed by deep contact intelligence.';
const pageUrl = 'https://markosh.com/sales/';

const whatItIs = [
  'Trained sales reps, SDRs, and appointment setters',
  'Lead researchers and CRM operators',
  'AI-assisted account research and call preparation',
  'Phone-led outreach with LinkedIn and email support',
  'CRM notes, reporting, and meeting qualification',
  'QA, team leads, and managed pod delivery',
];

const whatItIsNot = [
  'Not AI voice cold calling or robocalling',
  'Not a guaranteed appointment factory',
  'Not a guaranteed revenue service',
  'Not a replacement for your closer',
  'Not a "we call anyone for anyone" operation',
];

const models = [
  {
    id: undefined,
    num: '01',
    title: 'Retained Sales Rep',
    tagline: 'Your dedicated rep — our recruiting, training, tooling, and management',
    description: 'A premier B2B tech sales rep dedicated full-time to your business on a monthly retainer that covers the rep’s compensation. Markosh handles recruiting, sales training, enrichment tooling, QA, and day-to-day management — you get the output of a seasoned SDR without the hiring risk.',
    bestFor: 'B2B companies that want full-time, dedicated outbound coverage without building an internal SDR function.',
  },
  {
    id: undefined,
    num: '02',
    title: 'Appointment Setting',
    tagline: 'A managed program focused on booking qualified conversations',
    description: 'ICP definition, target-account research, contact enrichment, human-led multi-channel outreach, meeting qualification, and a clean hand-off to your closer — with weekly calibration and honest reporting on what the market is saying.',
    bestFor: 'Companies with a proven offer and closers ready to take calls, but no prospecting engine feeding them.',
  },
  {
    id: 'revenue-share',
    num: '03',
    title: 'Revenue-Share Partnership',
    tagline: 'We run the full sales motion; our upside is tied to yours',
    description: 'For a small number of deeply qualified offers, Markosh operates the entire sales cycle — prospecting through close — with compensation structured around shared revenue instead of flat fees. We only take this on when we believe in the offer, because we carry the execution risk with you.',
    bestFor: 'Companies with a proven product, healthy margins, and the delivery capacity to absorb new customers.',
  },
  {
    id: undefined,
    num: '04',
    title: 'Sales Research & CRM Operations',
    tagline: 'Cleaner data for your existing sellers',
    description: 'ICP research, account list building, lead enrichment, buying-signal research, CRM cleanup, pipeline hygiene, and reporting dashboards.',
    bestFor: 'Companies that already have callers or closers but need better data and sales operations.',
  },
];

const researchEngine = [
  'In-house contact-intelligence base covering 200M+ B2B profiles — enriched, verified, and suppression-checked before any list is used',
  'Reps trained on premium enrichment stacks: ZoomInfo, Clay, Apollo, intent and trigger-event data',
  'A scaled LinkedIn research bench for account mapping and multi-touch, human-written outreach',
  'A standing internal practice: the team continuously trains on the newest sales tooling and shares what works',
];

const aiDoes = [
  'Market and ICP research',
  'Account prioritization and lead scoring',
  'Trigger-event and buyer persona research',
  'Call preparation notes and objection research',
  'CRM cleanup and follow-up suggestions',
  'Talk-track drafts and pipeline reporting',
];

const aiNever = [
  'AI voice agents for cold calls',
  'Prerecorded voice messages or robocalling',
  'Automated cold-call spam',
  'Fully automated sales conversations',
];

const guardrails = [
  { title: 'Human-initiated dialing', detail: 'Manual, human-initiated calling — no autodialers into personal mobile numbers, no prerecorded messages, and no AI voices (the FCC classifies AI-generated voices as robocalls).' },
  { title: 'DNC and suppression workflows', detail: 'Scrubbing against federal and state do-not-call lists on the required refresh cycle, plus internal suppression lists honored across every campaign and number we operate.' },
  { title: 'State-law aware targeting', detail: 'Several states apply stricter mini-TCPA rules with no B2B exemption. Campaign targeting and channel choices account for state-level rules, not just federal ones.' },
  { title: 'Prospect-local calling windows', detail: 'Calls stay inside permitted hours in the prospect’s own time zone — tightened further where state rules require — with immediate opt-out handling.' },
  { title: 'Approved scripts only', detail: 'You approve the ICP, messaging, and talk tracks before any outreach starts.' },
  { title: 'Weekly QA and call review', detail: 'Every engagement has QA review, CRM notes, caller-ID reputation monitoring, and an audit trail you can inspect.' },
];

const launchNiches = [
  'Technical staffing & recruiting',
  'Freight brokers & 3PL',
  'Industrial distribution & automation',
  'Commercial facility services',
  'Commercial real estate services',
  'B2B SaaS & IT services',
];

const goodFit = [
  '5–50 sellers or a founder-led sales motion',
  'A clear B2B offer and a defined ICP',
  'A founder, AE, or closer available to take qualified conversations',
  'A meaningful deal size that justifies outbound',
  'CRM or pipeline discipline, and leadership that reviews weekly feedback',
];

const badFit = [
  'Low-ticket consumer offers',
  'No sales follow-up process or no closer available',
  'No clear ICP or untested offer',
  'A demand for "any meetings" at any cost',
  'A desire for high-volume, spam-style outreach',
];

const faqs = [
  {
    question: 'What is B2B Sales-as-a-Service?',
    answer: 'A managed sales execution service where Markosh provides trained sales reps, lead researchers, and CRM operators to support outbound sales activity for B2B companies — as a retained dedicated rep, an appointment-setting program, or a revenue-share partnership.',
  },
  {
    question: 'How do the three engagement models differ?',
    answer: 'Retained Sales Rep: a dedicated rep works only for you on a monthly retainer while Markosh handles recruiting, training, tooling, and management. Appointment Setting: a managed program focused on researching, reaching, and qualifying conversations for your closer. Revenue-Share Partnership: for deeply qualified offers, Markosh runs the full sales cycle with compensation tied to closed revenue.',
  },
  {
    question: 'Do you use AI voice or automated cold calling?',
    answer: 'No. Outreach is human-led. AI assists with research, preparation, documentation, prioritization, and reporting — never with the conversation itself.',
  },
  {
    question: 'Do you guarantee appointments or revenue?',
    answer: 'No. We commit to research quality, outreach discipline, CRM visibility, and honest weekly reporting. Appointments may happen, but they are not guaranteed.',
  },
  {
    question: 'How do the tech and sales businesses fit together?',
    answer: 'Both use the same operating model: research the problem, design the right team, deploy vetted talent, and manage execution. Some clients need engineers, some need sales reps, and some need a combined pod.',
  },
  {
    question: 'What is the 14-day sales rep experience?',
    answer: 'For approved B2B companies, Markosh assigns one trained sales rep for a controlled 14-day engagement — at our expense — focused on one ICP and one approved offer. It exists so you can judge our rep quality by watching real work, not a pitch deck, before committing to any model.',
  },
];

const extraSchemas = [
  generateServiceStructuredData('B2B Sales-as-a-Service', metaDescription),
  generateBreadcrumbStructuredData([
    { name: 'Home', url: 'https://markosh.com/' },
    { name: 'B2B Sales-as-a-Service', url: pageUrl },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical={pageUrl}
  extraSchemas={extraSchemas}
>
  <Header />
  <main id="main-content">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-4xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">B2B Sales-as-a-Service</p>
          <h1 class="mt-5 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
            Intelligence behind every rep. <span class="text-primary">A human on every call.</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            Markosh reps are not ordinary cold callers. They are trained B2B tech and services sellers, fluent in modern enrichment tooling, working from one of the deepest contact-intelligence bases in the market — in three engagement models: retained reps, appointment setting, and revenue-share partnerships.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <Button href="/sales-rep-trial" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
              Experience a Rep for 14 Days
              <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
            <Button href="/contact?outcome=sales-models" size="lg" variant="outline" data-astro-prefetch="hover" class="h-12 border-foreground/20 bg-transparent px-8 text-base hover:border-primary hover:bg-primary/5 hover:text-primary">
              Compare the Three Models
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- What it is / is not -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — The Service</p>
            <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl">
              Managed pipeline support, <span class="text-primary">clearly scoped</span>
            </h2>
          </div>
          <div class="mt-12 grid gap-x-12 gap-y-10 md:grid-cols-2">
            <div>
              <h3 class="border-b-2 border-foreground pb-3 font-headline text-lg font-bold text-signal">What you get</h3>
              <ul class="divide-y divide-border">
                {whatItIs.map((item) => (
                  <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="border-b-2 border-foreground pb-3 font-headline text-lg font-bold">What this is not</h3>
              <ul class="divide-y divide-border">
                {whatItIsNot.map((item) => (
                  <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- Models -->
    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">02 — Models</p>
            <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl">
              Three commercial models, <span class="text-primary">one operations layer</span>
            </h2>
          </div>
          <div class="mt-12 border-t border-border">
            {models.map((model) => (
              <article id={model.id} class="grid scroll-mt-28 gap-x-8 gap-y-3 border-b border-border py-8 sm:py-10 md:grid-cols-[3.5rem,1fr]">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">{model.num}</span>
                <div>
                  <p class="font-mono text-xs uppercase tracking-[0.14em] text-muted-foreground">{model.tagline}</p>
                  <h3 class="mt-2 font-headline text-3xl font-bold tracking-tight sm:text-4xl">{model.title}</h3>
                  <p class="mt-3 max-w-2xl text-muted-foreground">{model.description}</p>
                  <p class="mt-4 max-w-2xl text-sm leading-6 text-muted-foreground">
                    <span class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-foreground">Best for</span> — {model.bestFor}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- AI intelligence layer -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="grid gap-10 lg:grid-cols-[0.82fr,1.18fr] lg:items-start">
            <div class="lg:sticky lg:top-28">
              <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">03 — Sales Intelligence</p>
              <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl">
                AI behind the rep, <span class="text-primary">never instead of one</span>
              </h2>
              <p class="mt-6 text-lg text-muted-foreground">
                Our reps are not basic callers. Every conversation is backed by AI-assisted research, account intelligence, and structured reporting — and every conversation is held by a human.
              </p>
              <ul class="mt-8 divide-y divide-border border-t border-border">
                {researchEngine.map((item) => (
                  <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                ))}
              </ul>
            </div>
            <div class="grid gap-x-12 gap-y-10 sm:grid-cols-2">
              <div>
                <h3 class="border-b-2 border-foreground pb-3 font-headline text-lg font-bold text-signal">What AI does</h3>
                <ul class="divide-y divide-border">
                  {aiDoes.map((item) => (
                    <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                  ))}
                </ul>
              </div>
              <div>
                <h3 class="border-b-2 border-foreground pb-3 font-headline text-lg font-bold">What AI never does</h3>
                <ul class="divide-y divide-border">
                  {aiNever.map((item) => (
                    <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- Compliance guardrails (ink panel) -->
    <RevealSection>
      <section class="ink-panel">
        <div class="container mx-auto">
          <div class="max-w-3xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-signal sm:text-sm">04 — Operating Guardrails</p>
            <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-6xl">
              Compliance-aware <span class="text-signal">by design</span>
            </h2>
            <p class="mt-6 text-lg text-ink-foreground/70">
              Outbound done badly damages your brand and creates real legal exposure — DNC violations alone carry five-figure penalties per incident. Every Markosh engagement runs on the same guardrails.
            </p>
          </div>
          <div class="mt-14 grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
            {guardrails.map((item, index) => (
              <div class="border-t border-ink-foreground/20 pt-5">
                <p class="font-mono text-xs uppercase tracking-[0.14em] text-ink-foreground/60" aria-hidden="true">0{index + 1}</p>
                <h3 class="mt-3 font-headline text-lg font-bold">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-ink-foreground/70">{item.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- Fit + niches -->
    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto">
          <div class="max-w-2xl">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">05 — Fit</p>
            <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl">
              Who this <span class="text-primary">works for</span>
            </h2>
            <p class="mt-5 text-lg text-muted-foreground">
              We support B2B companies where targeted research and human conversation can create meaningful pipeline.
            </p>
          </div>
          <div class="mt-12 grid gap-x-12 gap-y-10 md:grid-cols-2">
            <div>
              <h3 class="border-b-2 border-foreground pb-3 font-headline text-lg font-bold text-signal">A strong fit</h3>
              <ul class="divide-y divide-border">
                {goodFit.map((item) => (
                  <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="border-b-2 border-foreground pb-3 font-headline text-lg font-bold">Not a fit</h3>
              <ul class="divide-y divide-border">
                {badFit.map((item) => (
                  <li class="py-3 text-sm leading-6 text-muted-foreground">{item}</li>
                ))}
              </ul>
            </div>
          </div>
          <div class="mt-14 border-t border-border pt-6">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Where we focus first</p>
            <p class="mt-3 font-mono text-sm leading-7 text-muted-foreground">{launchNiches.join(' · ')}</p>
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- Trial CTA -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <div class="grid gap-10 lg:grid-cols-[1.2fr,0.8fr] lg:items-center">
            <div>
              <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">06 — Proof of Capability</p>
              <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl">
                Experience a Markosh rep on your market — <span class="text-primary">14 days, our investment</span>
              </h2>
              <p class="mt-5 text-muted-foreground">
                Not a freebie — an audition. We put a trained rep on your ICP and let the work make the case: research quality, communication, outreach discipline, and CRM visibility, before you commit to any model.
              </p>
              <p class="mt-6 max-w-2xl border-t border-border pt-5 font-mono text-sm leading-6 text-foreground">
                For approved B2B companies only. One rep. One ICP. Capped activity. No appointment or closed-deal guarantee.
              </p>
            </div>
            <div class="flex flex-wrap gap-4 lg:justify-end">
              <Button href="/sales-rep-trial" size="lg" data-astro-prefetch="hover" class="btn-gradient h-12 px-8 text-base font-semibold">
                See the 14-Day Experience
              </Button>
            </div>
          </div>
        </div>
      </section>
    </RevealSection>

    <!-- FAQ -->
    <RevealSection>
      <section class="bg-background">
        <div class="container mx-auto max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">07 — FAQ</p>
          <h2 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl">Frequently asked questions</h2>
          <div class="mt-10 border-t border-border">
            {faqs.map((faq) => (
              <details class="group border-b border-border py-5">
                <summary class="cursor-pointer list-none font-headline text-lg font-bold marker:content-none [&::-webkit-details-marker]:hidden">
                  {faq.question}
                </summary>
                <p class="mt-3 text-muted-foreground">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>
