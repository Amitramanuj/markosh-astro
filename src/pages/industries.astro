---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';

const industries = [
  {
    num: '01',
    name: 'E-commerce',
    description: 'Scalable and secure online retail solutions to boost your sales.',
  },
  {
    num: '02',
    name: 'SaaS',
    description: 'Building robust and innovative Software-as-a-Service platforms.',
  },
  {
    num: '03',
    name: 'Healthcare',
    description: 'HIPAA-compliant software for the modern healthcare industry.',
  },
  {
    num: '04',
    name: 'Finance',
    description: 'Secure and reliable financial technology (FinTech) solutions.',
  },
  {
    num: '05',
    name: 'Education',
    description: 'Innovative EdTech platforms for enhanced learning experiences.',
  },
  {
    num: '06',
    name: 'Manufacturing',
    description: 'Custom software to optimize manufacturing processes and supply chains.',
  },
];
---

<BaseLayout
  title="Industries We Serve - Markosh"
  description="We combine our technology expertise with deep industry knowledge to deliver solutions that drive real business value."
  canonical="https://markosh.com/industries/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Industries</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Sector knowledge, <span class="text-primary">built in</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            We combine our technology expertise with deep industry knowledge to deliver solutions that drive real business value.
          </p>
        </div>
      </div>
    </section>

    <!-- Typographic industry index -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — Six Sectors</p>
          <div class="mt-8 border-t border-border">
            {industries.map((industry) => (
              <div class="grid gap-x-8 gap-y-3 border-b border-border py-8 sm:py-10 md:grid-cols-[3.5rem,1fr,1.2fr]">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">{industry.num}</span>
                <h2 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">{industry.name}</h2>
                <p class="max-w-xl text-muted-foreground md:pt-2">{industry.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>
