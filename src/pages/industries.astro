// Maps a solution route back to its engagement name for the card eyebrow.
const engagementName = (href: string) =>
  solutions.find((solution) => href.includes(solution.slug))?.name ?? '';

// Renders a sketch/glyph part. Dashed parts skip the draw animation:
// pathLength="1" would rescale their dash pattern into a solid stroke.
---

<BaseLayout
  title="Industries We Serve | Markosh"
  description="How our named solution engagements — outbound pipeline pods, workflow automation, embedded delivery — apply across eight sectors."
  canonical="https://markosh.com/industries/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Industries</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Sector knowledge, <span class="text-primary">built in</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            The same three engagements — outbound pods, workflow automation, embedded delivery — run differently in different sectors. This page shows how each one lands in the eight we work in most.
          </p>
        </div>
      </div>
    </section>

    <!-- Typographic industry index -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — Eight Sectors</p>
          <p class="mt-4 max-w-2xl text-muted-foreground">
            Select a sector to see how engagements there usually run and which of our named solutions
            apply — each one an engagement we have run before, backed by an anonymized case study.
          </p>
          <div class="mt-8 border-t border-border">
            {industries.map((industry, row) => (
              <details class="group border-b border-border">
                <summary class="relative block cursor-pointer list-none py-8 pr-10 sm:py-10 [&::-webkit-details-marker]:hidden">
                  <div class="grid gap-x-8 gap-y-3 md:grid-cols-[3.5rem,1fr,1.1fr,4rem]">
                    <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">{industry.num}</span>
                    <h2 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">{industry.name}</h2>
                    <p class="max-w-xl text-muted-foreground md:pt-2">{industry.description}</p>
                    <div class="hidden items-start justify-end md:flex md:pt-1">
                      <svg
                        class="h-10 w-10"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="hsl(var(--foreground) / 0.5)"
                        stroke-width="0.9"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        {industry.glyph.map((part, i) => {
                          const { tag, ...attrs } = part;
                          // astro-ignore: string-based dynamic tags type as bare
                          // IntrinsicAttributes, rejecting valid SVG attributes
                          const Tag = tag as any;
                          return (
                            <Tag
                              {...attrs}
                              pathLength="1"
                              class="glyph-draw"
                              style={`--draw-delay: ${(0.15 + row * 0.1 + i * 0.3).toFixed(2)}s`}
                            />
                          );
                        })}
                      </svg>
                    </div>
                  </div>
                  <svg
                    class="absolute right-0 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground transition-transform duration-300 group-open:rotate-45"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.25"
                    stroke-linecap="round"
                    aria-hidden="true"
                  >
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </summary>
                <div class="pb-10 md:pl-[5.5rem]">
                  <svg
                    class="h-14 w-full max-w-2xl sm:h-16"
                    viewBox="0 0 560 72"
                    preserveAspectRatio="xMinYMid meet"
                    fill="none"
                    stroke="hsl(var(--foreground) / 0.45)"
                    stroke-width="1"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {industry.sketch.parts.map((part, i) => {
                      const { tag, ...attrs } = part;
                      const Tag = tag as any;
                      return 'stroke-dasharray' in attrs ? (
                        <Tag {...attrs} stroke="hsl(var(--foreground) / 0.3)" />
                      ) : (
                        <Tag
                          {...attrs}
                          pathLength="1"
                          class="glyph-draw"
                          style={`--draw-delay: ${(0.1 + i * 0.12).toFixed(2)}s`}
                        />
                      );
                    })}
                  </svg>
                  <p class="mt-2 font-mono text-xs text-muted-foreground">Illustrative — {industry.sketch.caption}</p>
                  <p class="mt-8 max-w-2xl text-muted-foreground">{industry.narrative}</p>
                  <div class="mt-8 grid gap-10 md:grid-cols-3">
                    {industry.solutions.map((item) => (
                      <div>
                        <h3 class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary">{engagementName(item.href)}</h3>
                        <a href={item.href} data-astro-prefetch="hover" class="link-underline mt-4 inline-block font-semibold leading-snug">
                          {item.name}
                        </a>
                        <p class="mt-1 text-sm leading-6 text-muted-foreground">{item.text}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>
