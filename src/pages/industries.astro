---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';

// Glyph parts are stroke elements (24-grid, lucide-derived like ui/icons.tsx).
// Each gets pathLength="1" + .glyph-draw so it draws itself on reveal.
type GlyphPart = Record<string, string | number>;

interface Industry {
  num: string;
  name: string;
  description: string;
  glyph: GlyphPart[];
}

const industries: Industry[] = [
  {
    num: '01',
    name: 'E-commerce',
    description: 'Scalable and secure online retail solutions to boost your sales.',
    glyph: [
      { tag: 'path', d: 'M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12' },
      { tag: 'circle', cx: 8, cy: 21, r: 1 },
      { tag: 'circle', cx: 19, cy: 21, r: 1 },
    ],
  },
  {
    num: '02',
    name: 'SaaS',
    description: 'Building robust and innovative Software-as-a-Service platforms.',
    glyph: [{ tag: 'path', d: 'M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z' }],
  },
  {
    num: '03',
    name: 'Healthcare',
    description: 'HIPAA-compliant software for the modern healthcare industry.',
    glyph: [
      { tag: 'path', d: 'M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5Z' },
      { tag: 'path', d: 'M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27' },
    ],
  },
  {
    num: '04',
    name: 'Finance',
    description: 'Secure and reliable financial technology (FinTech) solutions.',
    glyph: [
      { tag: 'rect', x: 2, y: 6, width: 20, height: 12, rx: 2 },
      { tag: 'circle', cx: 12, cy: 12, r: 2 },
      { tag: 'path', d: 'M6 12h.01M18 12h.01' },
    ],
  },
  {
    num: '05',
    name: 'Education',
    description: 'Innovative EdTech platforms for enhanced learning experiences.',
    glyph: [
      { tag: 'path', d: 'M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z' },
      { tag: 'path', d: 'M22 10v6' },
      { tag: 'path', d: 'M6 12.5V16a6 3 0 0 0 12 0v-3.5' },
    ],
  },
  {
    num: '06',
    name: 'Manufacturing',
    description: 'Custom software to optimize manufacturing processes and supply chains.',
    glyph: [
      { tag: 'path', d: 'M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z' },
      { tag: 'path', d: 'M7 18h1M12 18h1M17 18h1' },
    ],
  },
  {
    num: '07',
    name: 'Marketing',
    description: 'Data-driven platforms and automation for modern marketing teams.',
    glyph: [
      { tag: 'path', d: 'm3 11 18-5v12L3 14v-3z' },
      { tag: 'path', d: 'M11.6 16.8a3 3 0 1 1-5.8-1.6' },
    ],
  },
  {
    num: '08',
    name: 'Real Estate',
    description: 'Property management, listing, and transaction software for real estate businesses.',
    glyph: [
      { tag: 'path', d: 'm3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
      { tag: 'path', d: 'M9 22V12h6v10' },
    ],
  },
];
---

<BaseLayout
  title="Industries We Serve - Markosh"
  description="We combine our technology expertise with deep industry knowledge to deliver solutions that drive real business value."
  canonical="https://markosh.com/industries/"
>
  <Header />
  <main id="main-content">
    <!-- Editorial hero -->
    <section class="relative isolate overflow-hidden pt-10 pb-12 md:pt-16">
      <div class="absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
      <div class="container mx-auto">
        <div class="max-w-3xl">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">Industries</p>
          <h1 class="mt-4 font-headline text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
            Sector knowledge, <span class="text-primary">built in</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            We combine our technology expertise with deep industry knowledge to deliver solutions that drive real business value.
          </p>
        </div>
      </div>
    </section>

    <!-- Typographic industry index -->
    <RevealSection>
      <section class="bg-secondary">
        <div class="container mx-auto">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary sm:text-sm">01 — Eight Sectors</p>
          <div class="mt-8 border-t border-border">
            {industries.map((industry, row) => (
              <div class="grid gap-x-8 gap-y-3 border-b border-border py-8 sm:py-10 md:grid-cols-[3.5rem,1fr,1.1fr,4rem]">
                <span class="font-mono text-sm text-muted-foreground" aria-hidden="true">{industry.num}</span>
                <h2 class="font-headline text-3xl font-bold tracking-tight sm:text-4xl">{industry.name}</h2>
                <p class="max-w-xl text-muted-foreground md:pt-2">{industry.description}</p>
                <div class="hidden items-start justify-end md:flex md:pt-1">
                  <svg
                    class="h-10 w-10"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="hsl(var(--foreground) / 0.5)"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {industry.glyph.map((part, i) => {
                      const { tag, ...attrs } = part;
                      // astro-ignore: string-based dynamic tags type as bare
                      // IntrinsicAttributes, rejecting valid SVG attributes
                      const Tag = tag as any;
                      return (
                        <Tag
                          {...attrs}
                          pathLength="1"
                          vector-effect="non-scaling-stroke"
                          class="glyph-draw"
                          style={`--draw-delay: ${(0.15 + row * 0.1 + i * 0.3).toFixed(2)}s`}
                        />
                      );
                    })}
                  </svg>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </RevealSection>

  </main>
  <Footer />
</BaseLayout>
