---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import RevealSection from '@/components/layout/RevealSection.astro';
import { solutions } from '@/lib/solutions';

// Glyph parts are stroke elements (24-grid, lucide-derived like ui/icons.tsx).
// Each gets pathLength="1" + .glyph-draw so it draws itself on reveal.
type GlyphPart = Record<string, string | number>;

interface IndustrySolution {
  name: string;
  text: string;
  /** Route to the solution page that runs this as a named engagement */
  href: string;
}

// Sketch parts share the glyph technique on a wide 560x72 canvas. Parts with
// a stroke-dasharray are "projected/future" strokes: they render statically
// dashed (pathLength="1" would rescale the dash pattern into a solid line).
interface Sketch {
  parts: GlyphPart[];
  caption: string;
}

interface Industry {
  num: string;
  name: string;
  description: string;
  glyph: GlyphPart[];
  /** How engagements in this sector usually go — one or two sentences */
  narrative: string;
  solutions: IndustrySolution[];
  sketch: Sketch;
}

