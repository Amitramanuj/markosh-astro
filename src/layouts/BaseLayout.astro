---
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/space-grotesk/latin-700.css';
import '../styles/global.css';
import TaskadeWidget from '../components/layout/TaskadeWidget.astro';
import { generateOrganizationStructuredData, generateWebsiteStructuredData, mergeSEOConfig, type SEOConfig } from '../lib/seo-utils';

export interface Props extends SEOConfig {
  /** Additional JSON-LD schemas to emit on this page (Article, BreadcrumbList, Service, ...) */
  extraSchemas?: object[];
}

const { extraSchemas = [], ...seoProps } = Astro.props;
const seoConfig = mergeSEOConfig(seoProps, Astro.url.pathname);
const structuredData = generateOrganizationStructuredData();
const websiteStructuredData = generateWebsiteStructuredData();
---

<!doctype html>
<html lang="en" class="!scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="generator" content={Astro.generator} />

    <!-- Flags JS availability so scroll-reveal styles only hide content when the observer below will run -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    
    <!-- Primary Meta Tags -->
    <title>{seoConfig.title}</title>
    <meta name="title" content={seoConfig.title} />
    <meta name="description" content={seoConfig.description} />
    <link rel="canonical" href={seoConfig.canonical} />
    {seoConfig.noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={seoConfig.type} />
    <meta property="og:url" content={seoConfig.canonical} />
    <meta property="og:title" content={seoConfig.title} />
    <meta property="og:description" content={seoConfig.description} />
    <meta property="og:image" content={seoConfig.image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Markosh — AI-first execution teams for software, talent, and revenue" />
    <meta property="og:site_name" content="Markosh" />
    <meta property="og:locale" content="en_US" />
    {seoConfig.publishedTime && <meta property="article:published_time" content={seoConfig.publishedTime} />}
    {seoConfig.modifiedTime && <meta property="article:modified_time" content={seoConfig.modifiedTime} />}
    {seoConfig.author && <meta property="article:author" content={seoConfig.author} />}
    {seoConfig.section && <meta property="article:section" content={seoConfig.section} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoConfig.title} />
    <meta name="twitter:description" content={seoConfig.description} />
    <meta name="twitter:image" content={seoConfig.image} />
    <meta name="twitter:image:alt" content="Markosh — AI-first execution teams for software, talent, and revenue" />
    
    <!-- Favicon and Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    
    <!-- Sitemap for search engines -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Performance and SEO optimizations -->
    <meta name="theme-color" content="#F9FAFB" />
    <meta name="color-scheme" content="light dark" />
    
    <!-- Security headers are served via Cloudflare Pages (public/_headers) -->

    <!-- Accessibility improvements -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- Fonts are self-hosted via Latin @fontsource subsets (imported in frontmatter) -->

    <!-- Critical CSS inlined for above-the-fold performance -->
    <style>
      /* Essential CSS loaded inline to prevent FOUC */
      :root {
        --background: 220 20% 98%;
        --foreground: 222 30% 12%;
        --primary: 222 30% 12%;
        --primary-foreground: 0 0% 100%;
        --accent: 222 30% 12%;
        --font-inter: 'Inter', system-ui, -apple-system, sans-serif;
        --font-display: 'Space Grotesk', system-ui, -apple-system, sans-serif;
        --radius: 0.75rem;
      }

      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      html{scroll-behavior:smooth;font-family:var(--font-inter);line-height:1.5;-webkit-text-size-adjust:100%;tab-size:4}
      body{min-height:100vh;background-color:hsl(var(--background));color:hsl(var(--foreground));font-family:var(--font-inter);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
      .container{width:100%;max-width:1200px;margin:0 auto;padding:0 1rem}
      .font-body{font-family:var(--font-inter)}
      .font-headline{font-family:var(--font-display)}
      .btn-gradient{background:hsl(var(--primary));color:#fff;border:none;border-radius:9999px;padding:0.75rem 1.5rem;font-weight:600;transition:all 0.2s ease}
      .btn-gradient:hover{transform:translateY(-2px);box-shadow:0 12px 30px -10px hsl(var(--primary) / 0.45)}
    </style>
    
    <!-- Structured Data for SEO -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)}></script>
    {extraSchemas.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    ))}
  </head>
  <body class="min-h-screen font-body antialiased">
    <!-- Skip link for screen readers -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-50 bg-primary text-primary-foreground px-4 py-2 rounded">
      Skip to main content
    </a>
    <slot />
    <TaskadeWidget />

    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Scroll-triggered section reveals (.reveal-section styles in global.css)
      const sections = document.querySelectorAll('.reveal-section');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        sections.forEach((section) => section.classList.add('is-visible'));
      } else {
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                sectionObserver.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px' }
        );
        sections.forEach((section) => sectionObserver.observe(section));
      }

      // Count-up for stats marked with data-countup (values like "120+" or "95%")
      const stats = document.querySelectorAll('[data-countup]');
      if (!reduceMotion && 'IntersectionObserver' in window && stats.length > 0) {
        const countUp = (el: Element) => {
          const match = /^(\d+)(.*)$/.exec((el.textContent ?? '').trim());
          if (!match) return;
          const target = Number(match[1]);
          const suffix = match[2] ?? '';
          const duration = 900;
          const start = performance.now();
          const tick = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(target * eased) + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        const statObserver = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              countUp(entry.target);
              statObserver.unobserve(entry.target);
            }
          }
        });
        stats.forEach((stat) => statObserver.observe(stat));
      }

      // Gentle parallax for backdrops marked with data-parallax (speed factor).
      // Transform-only and rAF-throttled so it never causes layout shift.
      const parallaxEls = document.querySelectorAll<HTMLElement>('[data-parallax]');
      if (!reduceMotion && parallaxEls.length > 0) {
        let ticking = false;
        const updateParallax = () => {
          for (const el of parallaxEls) {
            const speed = Number(el.dataset.parallax) || 0.12;
            el.style.transform = `translate3d(0, ${Math.round(window.scrollY * speed)}px, 0)`;
          }
          ticking = false;
        };
        window.addEventListener(
          'scroll',
          () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(updateParallax);
            }
          },
          { passive: true }
        );
      }
    </script>
  </body>
</html>

